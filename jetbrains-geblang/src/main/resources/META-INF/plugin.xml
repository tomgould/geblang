<idea-plugin>
    <id>com.dwgebler.geblang</id>
    <name>Geblang</name>
    <version>0.1.0</version>
    <vendor url="https://github.com/dwgebler/geblang">dwgebler</vendor>

    <description><![CDATA[
        <p>Geblang language support for IntelliJ-based IDEs.</p>
        <ul>
            <li>Syntax highlighting for .gb files (keywords, types, strings, numbers, comments, operators, decorators)</li>
            <li>File type recognition with icon</li>
            <li>Brace matching for {} [] ()</li>
            <li>Code folding for multi-line {} blocks and multi-line /* */ comments</li>
            <li>Line and block comment toggling (Ctrl+/ and Ctrl+Shift+/)</li>
            <li>Configurable color scheme under Settings > Editor > Color Scheme > Geblang</li>
            <li>LSP integration via LSP4IJ: diagnostics, code completion, go-to-definition,
                hover, find usages, rename, formatting — all powered by <code>geblang lsp</code></li>
            <li>Settings page under Languages &amp; Frameworks > Geblang to configure the
                path to the geblang executable</li>
            <li>Warns once per project session if the configured geblang executable cannot
                be found, with a one-click action to open settings and configure it</li>
            <li>"Geblang Test" run configuration: runs <code>geblang test --format teamcity</code>
                on a file or directory and renders results in the native test runner tree,
                with an optional <code>--tag</code> filter and working directory</li>
            <li>"Geblang File" run configuration: runs <code>geblang run</code> on a single
                file in a plain console, with optional working directory and program arguments</li>
            <li>Gutter Run/Debug markers: click-to-run next to a top-level <code>func main(</code>,
                a <code>class X extends test.Test</code> declaration, or an <code>@test</code>-decorated
                method, dispatching to the "Geblang File" or "Geblang Test" run configuration</li>
            <li>Step debugging via LSP4IJ's Debug Adapter Protocol support: set a breakpoint
                and click the gutter Debug icon on a <code>.gb</code> file to launch
                <code>geblang dap</code> and step over/into/out, inspect variables, and view
                multi-threaded call stacks</li>
            <li>Live templates (code snippets): type a prefix like <code>func</code> or
                <code>testclass</code> and press Tab to expand it, covering functions, classes,
                interfaces, enums, control flow, decorators, async, crypto, networking, and
                more - ported from the vscode-geblang snippet set</li>
            <li>TODO highlighting: <code># TODO: ...</code>, <code># FIXME: ...</code> and
                block-comment TODOs show up in the TODO tool window like any other language</li>
            <li>Spellchecking: prose in comments and string literals is spellchecked, and
                identifier names are split on camelCase/snake_case boundaries so only the
                misspelled word is flagged, not the whole identifier</li>
        </ul>
        <p><b>Requirements:</b> The <code>geblang</code> binary must be installed and accessible
        (on PATH or configured in settings) for LSP and debugging features to activate.
        LSP4IJ is declared as a required dependency and is installed automatically.</p>
    ]]></description>

    <change-notes><![CDATA[
        <b>0.1.0</b> (prototype)
        <ul>
            <li>Initial release: syntax highlighting, brace matching, code folding, commenter, LSP integration</li>
            <li>Step debugging: <code>geblang dap</code> wired into LSP4IJ's Debug Adapter Protocol support</li>
        </ul>
    ]]></change-notes>

    <idea-version since-build="242" until-build="243.*"/>

    <!-- Core platform — always present in every IntelliJ-based IDE -->
    <depends>com.intellij.modules.platform</depends>

    <!-- LSP4IJ — provides the LSP client; auto-installed as a plugin dependency -->
    <depends>com.redhat.devtools.lsp4ij</depends>

    <!-- JSON support (bundled platform module) - provides the JsonSchemaProviderFactory
         extension point used to register the geblang.yaml manifest schema. -->
    <depends>com.intellij.modules.json</depends>

    <!-- YAML support (bundled plugin, declared as a plain dependency since IC ships
         it out of the box). Its JsonSchemaEnabler makes the JSON schema engine
         apply to .yaml files, which is what lets the geblang.yaml manifest schema
         registered below drive completion and validation for that file. -->
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- File type: .gb -> Geblang language -->
        <fileType
            name="Geblang"
            implementationClass="com.dwgebler.geblang.language.GeblangFileType"
            language="Geblang"
            extensions="gb"
            fieldName="INSTANCE"/>

        <!-- Syntax highlighting -->
        <lang.syntaxHighlighterFactory
            language="Geblang"
            implementationClass="com.dwgebler.geblang.highlighting.GeblangSyntaxHighlighterFactory"/>

        <!-- Minimal flat-token PSI tree - no grammar. Foundation for folding,
             run-line markers, TODO highlighting and spellcheck. -->
        <lang.parserDefinition
            language="Geblang"
            implementationClass="com.dwgebler.geblang.psi.GeblangParserDefinition"/>

        <!-- Color settings page: Settings > Editor > Color Scheme > Geblang -->
        <colorSettingsPage
            implementation="com.dwgebler.geblang.highlighting.GeblangColorSettingsPage"/>

        <!-- Spellchecking: comment and string leaves are checked as prose;
             identifier leaves are split into camelCase/snake_case words. -->
        <spellchecker.support
            language="Geblang"
            implementationClass="com.dwgebler.geblang.highlighting.GeblangSpellcheckingStrategy"/>

        <!-- Commenter: Ctrl+/ → #  Ctrl+Shift+/ → /* */ -->
        <lang.commenter
            language="Geblang"
            implementationClass="com.dwgebler.geblang.editor.GeblangCommenter"/>

        <!-- Brace matching: {} [] () -->
        <lang.braceMatcher
            language="Geblang"
            implementationClass="com.dwgebler.geblang.editor.GeblangBraceMatcher"/>

        <!-- Code folding: multi-line {} blocks and multi-line /* */ comments -->
        <lang.foldingBuilder
            language="Geblang"
            implementationClass="com.dwgebler.geblang.editor.GeblangFoldingBuilder"/>

        <!-- Application-level settings service -->
        <applicationService
            serviceImplementation="com.dwgebler.geblang.settings.GeblangSettings"/>

        <!-- Settings page: Settings > Languages & Frameworks > Geblang -->
        <applicationConfigurable
            parentId="language"
            instance="com.dwgebler.geblang.settings.GeblangConfigurable"
            id="com.dwgebler.geblang.settings.GeblangConfigurable"
            displayName="Geblang"/>

        <!-- Notification group for plugin warnings, e.g. missing geblang executable -->
        <notificationGroup
            id="Geblang"
            displayType="BALLOON"/>

        <!-- Run configuration: runs "geblang test" (teamcity format) on a target and
             pipes its output into the native SMTestRunner test tree. -->
        <configurationType
            implementation="com.dwgebler.geblang.run.GeblangTestRunConfigurationType"/>

        <!-- Run configuration: runs "geblang run <file>" in a plain console. -->
        <configurationType
            implementation="com.dwgebler.geblang.run.GeblangFileRunConfigurationType"/>

        <!-- Run configuration producers: let gutter run/debug markers (and the
             "create configuration from context" gutter menu) resolve to the right
             run configuration for a click location. -->
        <runConfigurationProducer
            implementation="com.dwgebler.geblang.run.GeblangFileRunConfigurationProducer"/>
        <runConfigurationProducer
            implementation="com.dwgebler.geblang.run.GeblangTestRunConfigurationProducer"/>

        <!-- Gutter Run/Debug markers: func main(), test classes (extends test.Test),
             and @test-decorated methods. -->
        <runLineMarkerContributor
            language="Geblang"
            implementationClass="com.dwgebler.geblang.run.GeblangRunLineMarkerContributor"/>

        <!-- Live templates: context type restricting expansion to .gb files, and the
             bundled template set (func, class, testclass, etc.) -->
        <liveTemplateContext
            contextId="GEBLANG"
            implementation="com.dwgebler.geblang.templates.GeblangTemplateContextType"/>

        <defaultLiveTemplates file="/liveTemplates/Geblang"/>

        <!-- Exposes the bundled Geblang file templates under
             Settings > Editor > File and Code Templates -->
        <fileTemplateGroup implementation="com.dwgebler.geblang.actions.GeblangFileTemplateGroupFactory"/>

    </extensions>

    <!-- New > Geblang File: scaffolds a .gb file from the bundled templates
         (File / Class / Module / Test) -->
    <actions>
        <action
            id="Geblang.NewFile"
            class="com.dwgebler.geblang.actions.GeblangCreateFileAction">
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="NewFromTemplate"/>
        </action>
    </actions>

    <!-- Warn (once per project session) when a .gb file is opened but the configured
         geblang executable cannot be resolved, so LSP features silently staying off
         doesn't confuse the user. -->
    <projectListeners>
        <listener
            class="com.dwgebler.geblang.notification.GeblangMissingExecutableNotifier"
            topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    </projectListeners>

    <!-- LSP4IJ extensions: register the Geblang language server and file mapping -->
    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">

        <server
            id="geblang-lsp"
            name="Geblang Language Server"
            factoryClass="com.dwgebler.geblang.lsp.GeblangLspServerFactory">
            <description><![CDATA[
                Language server for Geblang (.gb files). Launched as <code>geblang lsp</code>
                (stdio transport). Provides diagnostics, completion, hover, go-to-definition,
                find usages, rename, and formatting via the canonical Geblang compiler.
                Configure the binary path in Settings > Languages &amp; Frameworks > Geblang.
            ]]></description>
        </server>

        <languageMapping
            language="Geblang"
            serverId="geblang-lsp"
            languageId="geblang"/>

        <debugAdapterServer
            id="geblang-dap"
            name="Geblang Debug Adapter"
            factoryClass="com.dwgebler.geblang.dap.GeblangDebugAdapterDescriptorFactory">
            <description><![CDATA[
                Debug adapter for Geblang (.gb files). Launched as <code>geblang dap</code>
                (stdio transport). Provides breakpoints, step over/into/out, and variable
                inspection via the canonical Geblang compiler's Debug Adapter Protocol server.
                Configure the binary path in Settings > Languages &amp; Frameworks > Geblang.
            ]]></description>
        </debugAdapterServer>

        <languageMapping
            language="Geblang"
            serverId="geblang-dap"
            languageId="geblang"/>

    </extensions>

    <!-- JSON schema for geblang.yaml: completion + validation for the package
         manifest. Applies to JSON directly and, via the YAML plugin's
         JsonSchemaEnabler (org.jetbrains.plugins.yaml, declared above), to
         geblang.yaml itself. -->
    <extensions defaultExtensionNs="JavaScript">
        <JsonSchema.ProviderFactory
            implementation="com.dwgebler.geblang.schema.GeblangManifestSchemaProviderFactory"/>
    </extensions>

</idea-plugin>
