/**
 * @title Explicit call-site type-argument enforcement
 * @summary Explicit <T> on a function or method call binds T; a dynamic
 *          any-typed argument that contradicts it throws at runtime. Matching
 *          arguments pass. (Statically-typed mismatches are rejected by the
 *          analyzer and are covered by Go-level tests.)
 */
import test;

func identity<T>(T value): T { return value; }

class Repo {
    func pick<T>(T value): T { return value; }
}

class ExplicitCallTypeArgsTest extends test.Test {
    @test
    func functionExplicitTypeArgEnforcedAtRuntime(): void {
        any x = 42;
        let threw = false;
        try {
            let r = identity<string>(x);
        } catch (RuntimeError e) {
            threw = true;
            this.assertTrue(e.message.contains("identity expects T for parameter 'value', got int"));
        }
        this.assertTrue(threw);
    }

    @test
    func functionExplicitTypeArgValid(): void {
        this.assertEquals("ok", identity<string>("ok"));
    }

    @test
    func methodExplicitTypeArgEnforcedAtRuntime(): void {
        any x = 42;
        let threw = false;
        try {
            let r = Repo().pick<string>(x);
        } catch (RuntimeError e) {
            threw = true;
            this.assertTrue(e.message.contains("Repo.pick expects T for parameter 'value', got int"));
        }
        this.assertTrue(threw);
    }

    @test
    func methodExplicitTypeArgValid(): void {
        this.assertEquals("ok", Repo().pick<string>("ok"));
    }
}
