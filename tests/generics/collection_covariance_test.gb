/**
 * @title Collection covariance test
 * @summary Built-in collections (list/set/dict) are covariant in their
 * element types: a list<Dog> is accepted where list<Animal> is expected,
 * and list<int> where list<any> is expected. An unrelated element type
 * (list<int> where list<string> is expected) is rejected at compile time
 * (static error). User generic classes stay invariant (see invariance_test).
 */
import test;

class Animal {
    func name(): string { return "animal"; }
}
class Dog extends Animal {
    func name(): string { return "dog"; }
}

func countAnimals(list<Animal> xs): int { return xs.length(); }
func countAny(list<any> xs): int { return xs.length(); }

class CollectionCovarianceTest extends test.Test {
    @test
    func acceptsSubtypeElement(): void {
        let list<Dog> dogs = [Dog(), Dog()];
        this.assertEquals(2, countAnimals(dogs));
    }

    @test
    func acceptsAnyElement(): void {
        let list<int> ints = [1, 2, 3];
        this.assertEquals(3, countAny(ints));
    }
}
