/**
 * @title Reified generics runtime test
 * @summary Runtime type assertions enforce declared element types for
 * list<T>, set<T>, dict<K,V> on assignment and method calls.
 */
import test;

class ReifiedRuntimeTest extends test.Test {
    @test
    func listElementTypeOnConstruction(): void {
        # Assigning a valid list<int> succeeds.
        list<int> xs = [1, 2, 3];
        this.assertEquals(3, xs.length());
    }

    @test
    func listRejectsWrongElement(): void {
        let threw = false;
        list<any> src = [1, "two", 3];
        try {
            list<int> bad = src;
        } catch (RuntimeError e) {
            threw = true;
        }
        this.assertTrue(threw);
    }

    @test
    func dictRejectsMismatchedValue(): void {
        let threw = false;
        dict<string, any> src = {"a": "not an int"};
        try {
            dict<string, int> bad = src;
        } catch (RuntimeError e) {
            threw = true;
        }
        this.assertTrue(threw);
    }

    @test
    func nullableGenericAcceptsNull(): void {
        ?list<int> xs = null;
        this.assertNull(xs);
        xs = [1, 2, 3];
        this.assertEquals(3, xs.length());
    }

    @test
    func nestedGenericMismatchRejected(): void {
        let threw = false;
        list<list<any>> src = [[1, 2], [3, "four"]];
        try {
            list<list<int>> bad = src;
        } catch (RuntimeError e) {
            threw = true;
        }
        this.assertTrue(threw);
    }
}
