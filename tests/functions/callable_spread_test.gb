/**
 * @title Spread arguments on callable values
 * @summary `(obj.fn)(...args)`, `fns[i](...args)`, and
 * `getFn()(...args)` all forward a spread list onto a callable
 * value. The bytecode VM compiles these the same way it compiles
 * a spread on a plain-identifier callable: pushes the receiver,
 * pushes static args, pushes the spread list, then emits
 * OpMethodCallSpread with `__invoke`.
 */
import test;

class Holder {
    callable adder;
    callable subtractor;

    func Holder() {
        this.adder = func(int a, int b, int c): int { return a + b + c; };
        this.subtractor = func(int a, int b): int { return a - b; };
    }
}

func getMul(): callable {
    return func(int a, int b, int c): int { return a * b * c; };
}

class CallableSpreadTest extends test.Test {
    @test
    func parenthesizedSelectorSpread(): void {
        let h = Holder();
        let args = [1, 2, 3];
        this.assertEquals(6, (h.adder)(...args));
        this.assertEquals(7, (h.subtractor)(...[10, 3]));
    }

    @test
    func indexedListCallableSpread(): void {
        let fns = [
            func(int a, int b): int { return a + b; },
            func(int a, int b): int { return a * b; },
        ];
        this.assertEquals(7, fns[0](...[3, 4]));
        this.assertEquals(12, fns[1](...[3, 4]));
    }

    @test
    func functionCallResultSpread(): void {
        this.assertEquals(24, getMul()(...[2, 3, 4]));
    }

    @test
    func staticArgsBeforeSpread(): void {
        let h = Holder();
        let rest = [2, 3];
        /* mix one static arg (1) with a 2-element spread for the
         * adder's 3-int signature. */
        this.assertEquals(6, (h.adder)(1, ...rest));
    }
}
