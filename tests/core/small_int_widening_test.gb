/**
 * @title SmallInt widens to decimal and float
 * @summary Integer results from builtin methods (list.length,
 *          string.length, range iterators) are returned as the
 *          compact SmallInt runtime type. The `as decimal` and
 *          `as float` casts previously only handled the big-int
 *          variant in the evaluator, so calling a method and then
 *          widening the result raised "cannot cast int to decimal"
 *          on the test runner (which uses the evaluator). Both
 *          variants now widen uniformly.
 */
import test;

class SmallIntWideningTest extends test.Test {
    @test
    func listLengthWidensToDecimal(): void {
        let xs = ["a", "b", "c"];
        decimal d = xs.length() as decimal;
        this.assertEquals("3.0000000000", d as string);
    }

    @test
    func listLengthWidensToFloat(): void {
        let xs = ["a", "b", "c"];
        float f = xs.length() as float;
        this.assertEquals("3", f as string);
    }

    @test
    func stringLengthWidensToDecimal(): void {
        decimal d = "hello".length() as decimal;
        this.assertEquals("5.0000000000", d as string);
    }

    @test
    func anyTypedSmallIntWidens(): void {
        any v = [1, 2, 3, 4].length();
        decimal d = v as decimal;
        this.assertEquals("4.0000000000", d as string);
    }

    @test
    func literalIntWidensTheSameWay(): void {
        decimal d = 5 as decimal;
        this.assertEquals("5.0000000000", d as string);
    }
}
