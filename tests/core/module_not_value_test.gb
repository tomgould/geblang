/**
 * @title module reference forms (1.15.0)
 * @summary A module identifier is not a first-class value: `let x = math`
 * is an error. These legal forms still work, proving the rule does not
 * over-reach: qualified member access, `dir(module)`, and
 * `reflect.module("name")` (a string).
 */
import test;
import math;
import sys;
import reflect;

class ModuleNotValueTest extends test.Test {

    @test
    func qualifiedMemberAccessWorks(): void {
        this.assertEquals(4.0, math.sqrt(16.0));
    }

    @test
    func dirOfModuleReturnsNonEmptyList(): void {
        let names = dir(sys);
        this.assertTrue(names.length() > 0);
    }

    @test
    func reflectModuleByStringDoesNotThrow(): void {
        /* string-form lookup is the valid introspection API; just exercise it */
        let m = reflect.module("math");
        this.assertTrue(true);
    }
}
