/**
 * @title Collection search (1.23.3)
 * @summary list.search / dict.search / string.search return every matching
 * locator (index / key / position) by value-equality or a callable predicate;
 * searchPattern matches strings against a regex. Empty list when nothing matches.
 */
import test;

class SearchTest extends test.Test {
    @test
    func listSearchByValue(): void {
        let xs = ["a", "b", "a", "c", "a"];
        this.assertEquals([0, 2, 4], xs.search("a"));
        this.assertEquals([], xs.search("z"));
    }

    @test
    func listSearchByPredicate(): void {
        let nums = [1, 5, 2, 8, 3];
        this.assertEquals([1, 3], nums.search(func(int n): bool { return n > 4; }));
    }

    @test
    func listSearchPattern(): void {
        let words = ["foo", "bar", "baz", "qux"];
        this.assertEquals([1, 2], words.searchPattern("^ba"));
    }

    @test
    func dictSearchByValue(): void {
        let d = {"x": 1, "y": 2, "z": 1};
        this.assertEquals(["x", "z"], d.search(1));
    }

    @test
    func dictSearchByPredicate(): void {
        let d = {"a": 10, "b": 3, "c": 20};
        this.assertEquals(["a", "c"], d.search(func(int v): bool { return v >= 10; }));
    }

    @test
    func dictSearchPattern(): void {
        let d = {"a": "cat", "b": "dog", "c": "cow"};
        this.assertEquals(["a", "c"], d.searchPattern("^c"));
    }

    @test
    func stringSearchSubstring(): void {
        this.assertEquals([2, 3], "hello".search("l"));
        /* overlapping start positions */
        this.assertEquals([0, 1], "aaa".search("aa"));
    }

    @test
    func stringSearchPattern(): void {
        this.assertEquals([1, 3, 5], "a1b2c3".searchPattern("[0-9]"));
    }

    @test
    func stringSearchPredicate(): void {
        this.assertEquals([2, 3], "hello".search(func(string c): bool { return c == "l"; }));
    }

    @test
    func emptyOnNoMatch(): void {
        this.assertEquals([], [1, 2, 3].search(9));
        this.assertEquals([], {"a": 1}.search(2));
        this.assertEquals([], "abc".search("z"));
    }
}
