/**
 * @title Multiple return values
 * @summary `return a, b` returns several values as a list that a matching
 * multi-assignment unpacks: `let a, b = f()` (declaration), `a, b = f()`
 * (assignment), and `a, b = b, a` (swap).
 */
import test;

class MultiReturnTest extends test.Test {
    func minMax(list<int> xs): list<int> {
        int lo = xs.get(0);
        int hi = xs.get(0);
        for (x in xs) {
            if (x < lo) { lo = x; }
            if (x > hi) { hi = x; }
        }
        return lo, hi;
    }

    @test
    func declareAndUnpack(): void {
        let lo, hi = this.minMax([3, 1, 4, 1, 5, 9, 2]);
        this.assertEquals(1, lo);
        this.assertEquals(9, hi);
    }

    @test
    func directListLiteralUnpack(): void {
        let a, b = 1, 2;
        this.assertEquals(1, a);
        this.assertEquals(2, b);
    }

    @test
    func assignmentUnpack(): void {
        int a = 0;
        int b = 0;
        a, b = 10, 20;
        this.assertEquals(10, a);
        this.assertEquals(20, b);
    }

    @test
    func swap(): void {
        let a, b = 1, 2;
        a, b = b, a;
        this.assertEquals(2, a);
        this.assertEquals(1, b);
    }

    @test
    func mixedTypes(): void {
        let n, s, flag = this.triple();
        this.assertEquals(7, n);
        this.assertEquals("hi", s);
        this.assertTrue(flag);
    }

    func triple(): list<any> { return 7, "hi", true; }

    @test
    func singleReturnUnaffected(): void {
        this.assertEquals(42, this.answer());
    }

    func answer(): int { return 42; }

    @test
    func tooManyTargetsRaises(): void {
        let threw = false;
        try {
            let a, b, c = [1, 2];
        } catch (RuntimeError e) {
            threw = true;
        }
        this.assertTrue(threw);
    }

    @test
    func fewerTargetsTakesPrefix(): void {
        let a, b = [1, 2, 3];
        this.assertEquals(1, a);
        this.assertEquals(2, b);
    }
}
