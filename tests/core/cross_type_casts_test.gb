/**
 * @title Cross-type casts + string module (1.0.2)
 * @summary `string <-> bytes` round-trip via UTF-8; `list <-> set`
 * de-duplicates / materializes; new `string` module with
 * `fromCodePoint`, `fromCodePoints`, `compare`, and `equalsFold`.
 */
import test;
import string;

class StringBytesCastTest extends test.Test {
    @test
    func stringToBytesEncodesUtf8(): void {
        let b = "hello" as bytes;
        this.assertEquals(5, b.length);
    }

    @test
    func bytesToStringDecodesUtf8(): void {
        let b = "hello" as bytes;
        this.assertEquals("hello", b as string);
    }

    @test
    func roundTripNonAscii(): void {
        let original = "rĂ©sumĂ© â‚¬";
        let b = original as bytes;
        this.assertEquals(original, b as string);
    }

    @test
    func invalidUtf8BytesRejected(): void {
        import bytes as bytesmod;
        let bad = bytesmod.fromHex("fffe80");
        try {
            let s = bad as string;
            this.fail("should have thrown on invalid UTF-8");
        } catch (RuntimeError e) {
            this.assertContains(e.getMessage(), "not valid UTF-8");
        }
    }
}

class ListSetCastTest extends test.Test {
    @test
    func listToSetDeduplicates(): void {
        let s = [1, 1, 2, 3, 3, 2] as set<int>;
        this.assertEquals(3, s.length);
    }

    @test
    func setToListMaterializes(): void {
        let original = {1, 2, 3};
        let l = original as list<int>;
        this.assertEquals(3, l.length);
        /* Iteration order is unspecified; assert content via set. */
        let backToSet = l as set<int>;
        this.assertEquals(3, backToSet.length);
    }

    @test
    func listSetRoundTripPreservesUniqueElements(): void {
        let xs = ["a", "b", "c", "b", "a"];
        let unique = (xs as set<string>) as list<string>;
        this.assertEquals(3, unique.length);
    }
}

class NullableCastBox {
    int x;
    func NullableCastBox(int x) { this.x = x; }
}

class FuncAsCallableTest extends test.Test {
    @test
    func castsAFunctionLiteralToCallable(): void {
        let f = func(int n): int { return n + 1; };
        let c = f as callable;
        this.assertEquals(6, c(5));
    }

    @test
    func castsAnyTypedFunctionValueToCallable(): void {
        /* Pre-1.0.3 the evaluator rejected `any-as-callable` for
         * function values with "cannot cast func to callable" while
         * the VM accepted it. Both backends should now match. */
        any g = func(string s): string { return s + "!"; };
        let c = g as callable;
        this.assertEquals("hi!", c("hi"));
    }

    @test
    func castsFunctionToFuncAndFunctionAliases(): void {
        /* The `callable` family covers `func`, `callable`, and
         * `function` aliases â€” all three are accepted on cast. */
        let f = func(): int { return 42; };
        let a = f as callable;
        let b = f as func;
        this.assertEquals(42, a());
        this.assertEquals(42, b());
    }
}

class NullableCastTest extends test.Test {
    @test
    func nullAsNullablePrimitive(): void {
        let a = null as ?int;
        this.assertEquals(null, a);
        let b = null as ?string;
        this.assertEquals(null, b);
    }

    @test
    func nullAsNullableUserClass(): void {
        let b = null as ?NullableCastBox;
        this.assertEquals(null, b);
    }

    @test
    func nonNullValueCastsThroughNullable(): void {
        /* `42 as ?int` should still succeed when the value is non-null,
         * falling through to the integer-cast path. */
        let n = 42 as ?int;
        this.assertEquals(42, n);
    }
}

class StringModuleTest extends test.Test {
    @test
    func fromCodePointAscii(): void {
        this.assertEquals("A", string.fromCodePoint(65));
        this.assertEquals(" ", string.fromCodePoint(32));
    }

    @test
    func fromCodePointUnicode(): void {
        this.assertEquals("â‚¬", string.fromCodePoint(8364));
        this.assertEquals("ä˝ ", string.fromCodePoint(0x4F60));
    }

    @test
    func fromCodePointsBuildsString(): void {
        this.assertEquals("Hi!", string.fromCodePoints([72, 105, 33]));
        this.assertEquals("ä˝ ĺĄ˝", string.fromCodePoints([0x4F60, 0x597D]));
        this.assertEquals("", string.fromCodePoints([]));
    }

    @test
    func fromCodePointRejectsSurrogates(): void {
        /* The U+D800..U+DFFF range is reserved for UTF-16 surrogate
         * halves and is not a valid scalar Unicode codepoint. */
        try {
            string.fromCodePoint(0xD800);
            this.fail("should reject surrogate");
        } catch (RuntimeError e) {
            this.assertContains(e.getMessage(), "not a valid Unicode codepoint");
        }
    }

    @test
    func compareThreeWay(): void {
        this.assertEquals(-1, string.compare("apple", "banana"));
        this.assertEquals(1, string.compare("banana", "apple"));
        this.assertEquals(0, string.compare("same", "same"));
    }

    @test
    func equalsFoldIsCaseInsensitive(): void {
        this.assertTrue(string.equalsFold("Hello", "HELLO"));
        this.assertTrue(string.equalsFold("CafĂ‰", "cafĂ©"));
        this.assertFalse(string.equalsFold("abc", "abd"));
    }

    @test
    func roundTripWithCodePointAt(): void {
        let n = "â‚¬".codePointAt(0);
        this.assertEquals("â‚¬", string.fromCodePoint(n));
    }
}

class AnimalForCast { func AnimalForCast() {} }
class DogForCast extends AnimalForCast { func DogForCast() { parent(); } }

class AsAnyCastTest extends test.Test {
    @test
    func widenPrimitiveToAny(): void {
        this.assertTrue(typeof("x" as any) == "string");
        this.assertTrue(typeof(5 as any) == "int");
    }

    @test
    func widenInstanceToAnyKeepsDynamicType(): void {
        let d = DogForCast();
        this.assertTrue(typeof(d as any) == "DogForCast");
    }

    @test
    func roundTripThroughAny(): void {
        let v = "hello" as any;
        this.assertEquals("hello", v as string);
    }

    @test
    func nullableAnyWidens(): void {
        this.assertTrue(typeof(5 as ?any) == "int");
    }
}
