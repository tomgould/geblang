/**
 * @title db parameter binding (1.9.0)
 * @summary Binding integer parameters and bytes BLOBs, then reading them back,
 * over a real in-memory SQLite connection (no mocks).
 */
import test;
import db;
import binary;
import async;
import io;
import path;

class DbTest extends test.Test {

    @test
    func concurrentMemoryWritesShareOneDb(): void {
        /* A private :memory: db is pinned to one connection, so concurrent
         * async writes all land in the same database rather than each seeing
         * a private empty one. */
        let c = db.connect("sqlite", ":memory:");
        c.exec("CREATE TABLE n (v INTEGER)");
        list<any> tasks = [];
        for (i in range(1, 25)) {
            tasks.push(async.run(func(): any { c.exec("INSERT INTO n (v) VALUES (1)"); return null; }));
        }
        for (t in tasks) {
            async.await(t);
        }
        let rows = c.query("SELECT COUNT(*) AS c FROM n").all();
        this.assertEquals(25, rows[0]["c"]);
    }

    func conn(): any {
        let c = db.connect("sqlite", ":memory:");
        c.exec("CREATE TABLE t (id INTEGER PRIMARY KEY, name TEXT, v BLOB)");
        return c;
    }

    @test
    func bindsIntegerParameter(): void {
        let c = this.conn();
        c.exec("INSERT INTO t (id, name) VALUES (?, ?)", 42, "alpha");
        c.exec("INSERT INTO t (id, name) VALUES (?, ?)", 7, "beta");
        let rows = c.query("SELECT name FROM t WHERE id = ?", 42).all();
        this.assertEquals(1, rows.length());
        this.assertEquals("alpha", rows[0]["name"]);
        /* integer column reads back as int */
        let ids = c.query("SELECT id FROM t WHERE id < ?", 100).all();
        this.assertEquals(2, ids.length());
    }

    @test
    func roundTripsBytesBlob(): void {
        let c = this.conn();
        let blob = binary.pack("<3f", 1.5f, 2.5f, 3.5f);
        c.exec("INSERT INTO t (id, v) VALUES (?, ?)", 1, blob);
        let rows = c.query("SELECT v FROM t WHERE id = ?", 1).all();
        this.assertEquals(1, rows.length());
        this.assertEquals("bytes", "${typeof(rows[0]["v"])}");
        let back = binary.unpack("<3f", rows[0]["v"] as bytes);
        this.assertEquals(3, back.length());
        this.assertEquals(2.5f, back[1] as float);
    }
}

class SqliteTuningTest extends test.Test {
    func walConn(): any {
        let file = path.join(io.tempDir("geb-db-wal-"), "app.sqlite");
        return db.Connection({
            "driver": "sqlite",
            "dsn": file,
            "wal": true,
            "synchronous": "NORMAL",
            "foreignKeys": true,
            "busyTimeoutMs": 8000,
            "tempStoreMemory": true,
        });
    }

    @test
    func tuningOptionsApplyToConnection(): void {
        let c = this.walConn();
        this.assertEquals("wal", c.query("PRAGMA journal_mode;").all()[0]["journal_mode"]);
        this.assertEquals(1, c.query("PRAGMA foreign_keys;").all()[0]["foreign_keys"]);
        this.assertEquals(1, c.query("PRAGMA synchronous;").all()[0]["synchronous"]);
        c.close();
    }

    @test
    func optimizeRunsWithoutError(): void {
        let c = this.walConn();
        c.exec("CREATE TABLE t (id INTEGER PRIMARY KEY)");
        c.optimize();
        c.close();
    }

    @test
    func rejectsInvalidSynchronous(): void {
        let file = path.join(io.tempDir("geb-db-bad-"), "x.sqlite");
        this.assertThrows(func(): void {
            db.Connection({"driver": "sqlite", "dsn": file, "synchronous": "SOMETIMES"});
        });
    }
}
