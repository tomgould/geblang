/**
 * @title http client error classification (1.24.0)
 * @summary Network / timeout / TLS failures surface as catchable IOError
 * subclasses (TimeoutError, TlsError) so callers can branch on the failure kind.
 */
import test;
import http;
import sys;

class HttpErrorsTest extends test.Test {

    func classify(callable f): string {
        try { f(); return "NO-ERROR"; }
        catch (TimeoutError e) { return "TimeoutError"; }
        catch (TlsError e) { return "TlsError"; }
        catch (IOError e) { return "IOError"; }
        catch (RuntimeError e) { return "RuntimeError"; }
    }

    func tlsServer(): dict<string, any> {
        let server = http.listen("127.0.0.1:0", func(dict<string, any> req): dict<string, any> {
            return {"status": 200, "body": "ok"};
        }, {"tls": {"selfSigned": true}});
        let port = (http.serverAddr(server).split(":")[1] as string) as int;
        sys.sleep(30);
        return {"server": server, "port": port};
    }

    @test
    func connectionRefusedIsIOError(): void {
        this.assertEquals("IOError", this.classify(func(): void {
            http.get("http://127.0.0.1:1/");
        }));
    }

    @test
    func selfSignedCertIsTlsError(): void {
        let s = this.tlsServer();
        let kind = this.classify(func(): void {
            http.get("https://127.0.0.1:" + ((s["port"] as int) as string) + "/");
        });
        http.shutdown(s["server"]);
        this.assertEquals("TlsError", kind);
    }

    @test
    func slowResponseIsTimeoutError(): void {
        let server = http.listen("127.0.0.1:0", func(dict<string, any> req): dict<string, any> {
            sys.sleep(400);
            return {"status": 200, "body": "ok"};
        });
        let port = (http.serverAddr(server).split(":")[1] as string) as int;
        sys.sleep(30);
        let kind = this.classify(func(): void {
            http.requestWithOptions({"method": "GET", "url": "http://127.0.0.1:" + (port as string) + "/", "timeoutMs": 80});
        });
        http.shutdown(server);
        this.assertEquals("TimeoutError", kind);
    }

    @test
    func tlsErrorIsAlsoAnIOError(): void {
        let s = this.tlsServer();
        let caught = "none";
        try {
            http.get("https://127.0.0.1:" + ((s["port"] as int) as string) + "/");
        } catch (IOError e) {
            caught = "IOError";
        }
        http.shutdown(s["server"]);
        this.assertEquals("IOError", caught);
    }
}
