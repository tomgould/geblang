/**
 * @title ndarray module test
 * @summary N-dimensional arrays: constructors and dtype inference,
 *          zero-copy views, broadcasting, reductions (whole and per
 *          axis), comparisons with masked selection, linear algebra,
 *          and seeded random reproducibility.
 */
import test;
import ndarray as nd;

class NDArrayTest extends test.Test {
    @test
    func constructorsAndDtypeInference(): void {
        let f = nd.array([[1.0, 2.0], [3.0, 4.0]]);
        this.assertEquals("float64", f.dtype());
        this.assertEquals([2, 2], f.shape());
        this.assertEquals(4, f.size());

        let i = nd.array([1, 2, 3]);
        this.assertEquals("int64", i.dtype());

        this.assertEquals([0, 2, 4, 6, 8], nd.arange(0, 10, 2).toList());
        this.assertEquals([0, 0.5, 1], nd.linspace(0.0, 1.0, 3).toList());
        this.assertEquals([[1, 0], [0, 1]], nd.eye(2).toList());
        this.assertEquals([[7, 7], [7, 7]], nd.full([2, 2], 7).toList());
    }

    @test
    func viewsShareStorage(): void {
        let a = nd.array([[1.0, 2.0], [3.0, 4.0]]);
        let row = a.slice([[1, 2]]);
        row.set([0, 0], 99.0);
        this.assertEquals(99.0, a.get([1, 0]));
        this.assertEquals([[1, 99], [2, 4]], a.t().toList());

        let copied = a.copy();
        copied.set([0, 0], -1.0);
        this.assertEquals(1.0, a.get([0, 0]));
    }

    @test
    func broadcastingAndElementwise(): void {
        let row = nd.array([[1.0, 2.0, 3.0]]);
        let col = nd.array([[10.0], [20.0]]);
        this.assertEquals([[11, 12, 13], [21, 22, 23]], row.add(col).toList());
        this.assertEquals([[2, 4, 6]], row.mulScalar(2).toList());
        this.assertEquals([1, 2, 3], nd.array([1.0, 4.0, 9.0]).sqrt().toList());

        /* int / int promotes to float64 (true division) */
        this.assertEquals("float64", nd.array([4, 2]).div(nd.array([2, 4])).dtype());
    }

    @test
    func reductionsWholeAndAxis(): void {
        let a = nd.array([[1.0, 2.0], [3.0, 4.0]]);
        this.assertEquals(10.0, a.sum());
        this.assertEquals(2.5, a.mean());
        this.assertEquals(1.0, a.min());
        this.assertEquals(4.0, a.max());
        this.assertEquals([4, 6], a.sum({"axis": 0}).toList());
        this.assertEquals([3, 7], a.sum({"axis": 1}).toList());
        this.assertEquals(3, a.argmax());
        this.assertEquals([1, 3, 6, 10], a.cumsum().toList());

        /* int sums stay int */
        this.assertEquals(6, nd.array([1, 2, 3]).sum());
    }

    @test
    func comparisonsAndWhere(): void {
        let a = nd.array([1.0, 5.0, 2.0, 8.0]);
        let mask = a.gt(2.0);
        this.assertEquals("int64", mask.dtype());
        this.assertEquals([0, 1, 0, 1], mask.toList());
        this.assertEquals([5, 8], a.where(mask).toList());
    }

    @test
    func linearAlgebra(): void {
        let a = nd.array([[2.0, 0.0], [0.0, 4.0]]);
        this.assertEquals([1, 2], nd.solve(a, nd.array([2.0, 8.0])).toList());
        this.assertEquals(8.0, nd.det(a));
        this.assertEquals([[1, 0], [0, 1]], a.matmul(nd.inv(a)).toList());
        this.assertEquals(11.0, nd.array([1.0, 2.0]).dot(nd.array([3.0, 4.0])));
    }

    @test
    func seededRandomIsReproducible(): void {
        let a = nd.random([2, 3], {"seed": 42});
        let b = nd.random([2, 3], {"seed": 42});
        this.assertEquals(6, a.eq(b).sum());
        this.assertEquals([2, 3], a.shape());
    }

    @test
    func errorsAreCatchable(): void {
        try {
            nd.inv(nd.array([[1.0, 2.0], [2.0, 4.0]]));
            this.fail("singular matrix must throw");
        } catch (RuntimeError e) {
            this.assertTrue(e.message.contains("singular"));
        }
        try {
            nd.array([[1.0], [2.0, 3.0]]);
            this.fail("ragged rows must throw");
        } catch (RuntimeError e) {
            this.assertTrue(e.message.contains("equal length"));
        }
    }
}
