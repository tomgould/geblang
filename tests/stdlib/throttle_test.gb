/**
 * @title async.rate throttle test
 * @summary async.rate.throttle caches results within the configured window.
 */
import test;
import async.rate as rate;
import time;

class ThrottleTest extends test.Test {
    @test
    func throttledCallsCacheWithinWindow(): void {
        int calls = 0;
        let work = func(int x): int {
            calls = calls + 1;
            return x * 2;
        };
        let throttled = rate.throttle(work, 200);

        # Three rapid calls within 200ms should all run the underlying
        # function at most once.
        let a = throttled(5);
        let b = throttled(7);
        let c = throttled(9);
        this.assertEquals(1, calls);
        # All three calls return the first invocation's result.
        this.assertEquals(10, a);
        this.assertEquals(10, b);
        this.assertEquals(10, c);
    }

    @test
    func throttleAllowsCallAfterWindow(): void {
        int calls = 0;
        let work = func(int x): int {
            calls = calls + 1;
            return x;
        };
        let throttled = rate.throttle(work, 50);

        throttled(1);
        time.sleep(75);
        throttled(2);
        this.assertEquals(2, calls);
    }
}
