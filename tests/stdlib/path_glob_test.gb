/**
 * @title path.glob recursive matching
 * @summary Plain globs use filepath.Glob; ** expands to recursive.
 */
import test;
import path;
import io;

class PathGlobTest extends test.Test {
    @test
    func nonRecursiveMatch(): void {
        let matches = path.glob("/tmp/*.gb");
        this.assertTrue(matches.length >= 0);
        for (m in matches) {
            this.assertTrue(m.endsWith(".gb"));
        }
    }

    @test
    func recursiveMatch(): void {
        # Self-contained tree so the test does not depend on machine paths.
        let dir = io.tempDir("geb-glob-*");
        io.mkdir(path.join(dir, "sub/deep"), 0o755);
        io.writeText(path.join(dir, "sub/b.go"), "package x");
        io.writeText(path.join(dir, "sub/deep/c.go"), "package x");
        io.writeText(path.join(dir, "sub/note.txt"), "ignore");
        let matches = path.glob(path.join(dir, "**/*.go"));
        this.assertTrue(matches.length > 1);
        for (m in matches) {
            this.assertTrue(m.endsWith(".go"));
        }
    }

    @test
    func patternWithNoMatchesReturnsEmptyList(): void {
        let matches = path.glob("/tmp/__no_such_pattern__-*.xyzzy");
        this.assertEquals(0, matches.length);
    }
}
