/**
 * @title time stdlib test
 * @summary time.now / elapsed / sleep + unix-time precision helpers.
 */
import test;
import time;
import datetime;

class TimeTest extends test.Test {
    @test
    func nowReturnsPositiveWallMillis(): void {
        # now() is the wall clock, which is not monotonic; assert only that it
        # is a sane positive millisecond timestamp. Monotonic increase is
        # covered by monotonicNeverDecreases.
        let t = time.now();
        this.assertTrue(t > 1000000000000);
    }

    @test
    func elapsedReportsMillisSincePast(): void {
        # Use a start fixed 10s in the past rather than a live sleep, so the
        # delta is deterministically positive even if the wall clock steps.
        let elapsed = time.elapsed(time.now() - 10000);
        this.assertTrue(elapsed >= 5000);
        this.assertTrue(elapsed < 60000);
    }

    @test
    func sleepZeroIsImmediate(): void {
        let t0 = time.now();
        time.sleep(0);
        let elapsed = time.elapsed(t0);
        this.assertTrue(elapsed < 100);
    }

    @test
    func unixMatchesDatetimeNowUnix(): void {
        let a = time.unix();
        let b = datetime.nowUnix();
        this.assertTrue(a >= b - 1 && a <= b + 1);
    }

    @test
    func unixMilliMatchesNow(): void {
        let m = time.unixMilli();
        let n = time.now();
        # Two calls back to back differ by at most a few ms.
        this.assertTrue(m >= n - 50 && m <= n + 50);
    }

    @test
    func unitsAreInternallyConsistent(): void {
        let s = time.unix();
        let ms = time.unixMilli();
        let us = time.unixMicro();
        let ns = time.unixNano();
        # Round-trip via integer division (1s slack for cross-call jitter).
        this.assertTrue(ms / 1000 >= s - 1 && ms / 1000 <= s + 1);
        this.assertTrue(us / 1000 >= ms - 50 && us / 1000 <= ms + 50);
        this.assertTrue(ns / 1000 >= us - 50_000 && ns / 1000 <= us + 50_000);
    }

    @test
    func unixFloatHasSubSecondFraction(): void {
        let s = time.unix();
        let f = time.unixFloat();
        let asInt = f.toInt();
        # asInt is the second bucket f belongs to; should match s within 1s drift.
        this.assertTrue(asInt >= s - 1 && asInt <= s + 1);
    }

    @test
    func unixDecimalLosslessSeconds(): void {
        let s = time.unix();
        let d = time.unixDecimal();
        let asInt = d.toInt();
        this.assertTrue(asInt >= s - 1 && asInt <= s + 1);
    }

    @test
    func elapsedFloatReportsPositiveDelta(): void {
        # Start fixed 10s in the past, so elapsed is ~10 regardless of any wall
        # clock jitter during the test (unixFloat/elapsedFloat are wall-clock).
        let elapsed = time.elapsedFloat(time.unixFloat() - 10.0.toFloat());
        this.assertTrue(elapsed > 1.0.toFloat());
        this.assertTrue(elapsed < 60.0.toFloat());
    }

    @test
    func elapsedFloatAcceptsDecimalStart(): void {
        # A decimal start, also fixed in the past for a deterministic delta.
        let elapsed = time.elapsedFloat(time.unixDecimal() - 10);
        this.assertTrue(elapsed > 1.0.toFloat());
    }

    @test
    func monotonicNeverDecreases(): void {
        /* Unlike time.now / time.unix (wall clock, which can step
           backwards), time.monotonic only advances - the correct
           source for durations and TTLs. */
        let a = time.monotonic();
        time.sleep(10);
        let b = time.monotonic();
        this.assertTrue(b >= a);
        this.assertTrue(b - a >= 10);
    }

    @test
    func humanizeSubSecond(): void {
        this.assertEquals("45ms", time.humanize(45));
        this.assertEquals("999ms", time.humanize(999));
        this.assertEquals("0ms", time.humanize(0));
    }

    @test
    func humanizeSeconds(): void {
        this.assertEquals("1s", time.humanize(1000));
        this.assertEquals("1.5s", time.humanize(1500));
        this.assertEquals("1.2s", time.humanize(1230));
        this.assertEquals("45s", time.humanize(45000));
    }

    @test
    func humanizeMinutesAndUp(): void {
        this.assertEquals("1m", time.humanize(59999));
        this.assertEquals("3m 4s", time.humanize(184000));
        this.assertEquals("2h 5m", time.humanize(7501000));
        this.assertEquals("1d 1h", time.humanize(90061000));
        this.assertEquals("1h", time.humanize(3600000));
    }

    @test
    func humanizeNegative(): void {
        this.assertEquals("-1.5s", time.humanize(-1500));
    }
}
