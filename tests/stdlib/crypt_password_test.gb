/**
 * @title PHP-compatible password hashing (1.4.1)
 * @summary crypt.passwordHash / passwordVerify round-trip with PHP's
 *          password_hash format ($2y$ bcrypt and $argon2*$ PHC strings).
 */
import test;
import crypt;

class CryptPasswordTest extends test.Test {
    @test
    func bcryptOutputUsesPhpPrefix(): void {
        let hash = crypt.passwordHash("hunter2");
        this.assertTrue(hash.startsWith("$2y$"));
        this.assertTrue(crypt.passwordVerify("hunter2", hash));
        this.assertEquals(false, crypt.passwordVerify("wrong", hash));
    }

    @test
    func bcryptHonoursCostOption(): void {
        let hash = crypt.passwordHash("hunter2", {"algorithm": "bcrypt", "cost": 4});
        this.assertTrue(hash.startsWith("$2y$04$"));
        this.assertTrue(crypt.passwordVerify("hunter2", hash));
    }

    @test
    func verifyAcceptsAllBcryptVersions(): void {
        let goEmitted = crypt.bcryptHash("hunter2", 4);
        this.assertTrue(goEmitted.startsWith("$2a$"));
        this.assertTrue(crypt.passwordVerify("hunter2", goEmitted));

        let phpStyle = "$2y$" + goEmitted.substring(4);
        this.assertTrue(crypt.passwordVerify("hunter2", phpStyle));

        let bbStyle = "$2b$" + goEmitted.substring(4);
        this.assertTrue(crypt.passwordVerify("hunter2", bbStyle));
    }

    @test
    func argon2idRoundTrips(): void {
        let hash = crypt.passwordHash("hunter2", {"algorithm": "argon2id"});
        this.assertTrue(hash.startsWith("$argon2id$"));
        this.assertTrue(crypt.passwordVerify("hunter2", hash));
        this.assertEquals(false, crypt.passwordVerify("wrong", hash));
    }

    @test
    func argon2iRoundTrips(): void {
        let hash = crypt.passwordHash("hunter2", {"algorithm": "argon2i"});
        this.assertTrue(hash.startsWith("$argon2i$"));
        this.assertTrue(crypt.passwordVerify("hunter2", hash));
        this.assertEquals(false, crypt.passwordVerify("wrong", hash));
    }

    @test
    func verifiesPhpEmittedBcrypt(): void {
        /* Hash produced by PHP password_hash("hunter2", PASSWORD_BCRYPT, ['cost' => 4]). */
        let phpHash = "$2y$04$cAkpTnTMpIpo0m80Unnoc.XTtHYSLKMe1xOUiV8i7MRi.q6noRl3y";
        this.assertTrue(crypt.passwordVerify("hunter2", phpHash));
        this.assertEquals(false, crypt.passwordVerify("wrong", phpHash));
    }

    @test
    func verifyRejectsGarbage(): void {
        this.assertEquals(false, crypt.passwordVerify("hunter2", "not-a-hash"));
        this.assertEquals(false, crypt.passwordVerify("hunter2", "$argon2id$v=99$junk"));
        this.assertEquals(false, crypt.passwordVerify("hunter2", ""));
    }

    @test
    func passwordHashRejectsUnknownAlgorithm(): void {
        this.assertThrows(func(): void {
            crypt.passwordHash("hunter2", {"algorithm": "scrypt"});
        });
    }
}
