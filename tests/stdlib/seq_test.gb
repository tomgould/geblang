/**
 * @title seq.Stream (1.9.0)
 * @summary Lazy fluent pipeline: chained map/filter/etc. run nothing until a
 * terminal op pulls, with no intermediate lists materialised.
 */
import test;
import collections;
import seq;

class CollectionsStreamTest extends test.Test {

    @test
    func mapFilterSum(): void {
        let total = seq.stream([1, 2, 3, 4, 5, 6])
            .filter(func(any n): bool { return (n as int) % 2 == 0; })
            .map(func(any n): any { return (n as int) * (n as int); })
            .sum();
        this.assertEquals(56, total);
    }

    @test
    func isLazyAndShortCircuits(): void {
        /* first() over a huge range returns immediately; if the stream were
         * eager this would never finish. A peek counter proves only a tiny
         * number of elements are pulled (generators look ahead by a small
         * constant, so we assert "few", not an exact count). */
        let pulls = [0];
        let r = seq.stream(1..1000000)
            .peek(func(any n): void { pulls[0] = (pulls[0] as int) + 1; })
            .map(func(any n): any { return (n as int) * 2; })
            .first();
        this.assertEquals(2, r);
        this.assertTrue((pulls[0] as int) < 100);
    }

    @test
    func takeDropTakeWhileDropWhile(): void {
        this.assertEquals([2, 3, 4], seq.stream([1, 2, 3, 4, 5, 6]).drop(1).take(3).toList());
        this.assertEquals([1, 2, 3], seq.stream([1, 2, 3, 4, 1]).takeWhile(func(any n): bool { return (n as int) < 4; }).toList());
        this.assertEquals([3, 1], seq.stream([1, 2, 3, 1]).dropWhile(func(any n): bool { return (n as int) < 3; }).toList());
    }

    @test
    func flatMapAndDistinct(): void {
        this.assertEquals([1, 2, 3, 4, 5], seq.stream([[1, 2], [3], [4, 5]]).flatMap(func(any g): any { return g; }).toList());
        this.assertEquals([3, 1, 2], seq.stream([3, 1, 3, 2, 1, 2]).distinct().toList());
    }

    @test
    func sortedAndSortedBy(): void {
        this.assertEquals([1, 2, 3], seq.stream([3, 1, 2]).sorted().toList());
        let byKey = seq.stream([{"n": 3}, {"n": 1}, {"n": 2}])
            .sortedBy(func(any d): any { return (d as dict<string, any>)["n"]; })
            .map(func(any d): any { return (d as dict<string, any>)["n"]; })
            .toList();
        this.assertEquals([1, 2, 3], byKey);
        this.assertEquals([3, 2, 1], seq.stream([2, 1, 3]).sortedBy(func(any d): any { return d; }, true).toList());
    }

    @test
    func terminals(): void {
        this.assertEquals(4, seq.stream([1, 2, 3, 4]).count());
        this.assertEquals(10, seq.stream([1, 2, 3, 4]).reduce(0, func(any a, any b): any { return a + b; }));
        this.assertEquals(2, seq.stream([1, 2, 3]).find(func(any n): bool { return (n as int) > 1; }));
        this.assertTrue(seq.stream([2, 4, 6]).all(func(any n): bool { return (n as int) % 2 == 0; }));
        this.assertTrue(seq.stream([1, 2, 3]).any(func(any n): bool { return (n as int) == 2; }));
        this.assertTrue(seq.stream([1, 2, 3]).none(func(any n): bool { return (n as int) > 5; }));
        this.assertEquals(1, seq.stream([3, 1, 2]).min());
        this.assertEquals(3, seq.stream([3, 1, 2]).max());
        this.assertEquals("1-2-3", seq.stream([1, 2, 3]).map(func(any n): any { return "${n}"; }).join("-"));
        this.assertEquals(3, seq.stream([1, 1, 2, 3, 3]).toSet().length());
    }

    @test
    func emptyStreamEdges(): void {
        this.assertEquals(0, seq.stream([]).sum());
        this.assertNull(seq.stream([]).first());
        this.assertEquals("none", seq.stream([]).firstOr("none"));
        this.assertNull(seq.stream([]).min());
        this.assertEquals(0, seq.stream([]).count());
        this.assertTrue(seq.stream([]).all(func(any n): bool { return false; }));
    }

    @test
    func nativeModuleStillWorks(): void {
        /* The Stream class lives alongside the native collections functions. */
        this.assertEquals(3, collections.length([1, 2, 3]));
        this.assertEquals([1, 2, 3], collections.sorted([3, 1, 2]));
    }
}
