/**
 * @title messaging.sns publish + subscription dispatch
 * @summary SNS Publish requests are signed with sigv4 and dispatched
 * to the SNS regional endpoint. `subscribe(handler)` requires a
 * paired SQS queue and polls it; without one, the call throws.
 */
import test;
import http;
import sys;
import io;
import path;
import messaging;

/* Mock both SNS and SQS endpoints on the same listener. SNS POSTs
 * to `/` with sigv4 form params; SQS POSTs to a queue path. The
 * handler dispatches by inspecting the path + body. The default
 * SNS endpoint points at the real AWS host, so this test overrides
 * by passing a non-AWS opts.endpoint that the implementation
 * deliberately does NOT support yet; instead we drive publish()
 * via the SQS-paired form below.
 *
 * The cleaner pattern for the publish() test would be to make the
 * endpoint overridable. For now we exercise the signing path via
 * unit-level checks on the SnsTopic class shape.
 */
func startMockSqs(): dict<string, any> {
    let dir = io.tempDir("snsmock_");
    let server = http.listen("127.0.0.1:0", func(dict<string, any> req): dict<string, any> {
        let body = req["body"] as string;
        if (body.contains("Action=ReceiveMessage")) {
            if (io.exists(path.join(dir, "delivered"))) {
                return {"status": 200, "headers": {}, "body": "<ReceiveMessageResponse><ReceiveMessageResult></ReceiveMessageResult></ReceiveMessageResponse>"};
            }
            io.writeText(path.join(dir, "delivered"), "1");
            return {"status": 200, "headers": {}, "body":
                "<ReceiveMessageResponse><ReceiveMessageResult><Message>" +
                "<MessageId>m-1</MessageId><ReceiptHandle>h-1</ReceiptHandle>" +
                "<Body>{\"Type\":\"Notification\",\"Message\":\"hello\"}</Body>" +
                "</Message></ReceiveMessageResult></ReceiveMessageResponse>"};
        }
        if (body.contains("Action=DeleteMessage")) {
            io.writeText(path.join(dir, "acked"), "1");
            return {"status": 200, "headers": {}, "body": "<DeleteMessageResponse/>"};
        }
        return {"status": 400, "headers": {}, "body": "unknown"};
    });
    let addr = http.serverAddr(server);
    sys.sleep(20);
    return {"server": server, "queueUrl": "http://" + addr + "/123/snstest", "dir": dir};
}

class MessagingSnsTest extends test.Test {
    @test
    func connectRequiresRegion(): void {
        this.assertThrows(func(): void {
            messaging.topic({
                "driver":    "sns",
                "topicArn":  "arn:aws:sns:us-east-1:123:t",
                "accessKey": "k",
                "secretKey": "s"
            });
        });
    }

    @test
    func connectRequiresTopicArn(): void {
        this.assertThrows(func(): void {
            messaging.topic({
                "driver":    "sns",
                "region":    "us-east-1",
                "accessKey": "k",
                "secretKey": "s"
            });
        });
    }

    @test
    func connectSucceedsWithoutQueueUrlButSubscribeThrows(): void {
        let t = messaging.topic({
            "driver":    "sns",
            "region":    "us-east-1",
            "topicArn":  "arn:aws:sns:us-east-1:123:t",
            "accessKey": "k",
            "secretKey": "s"
        });
        this.assertThrows(func(): void {
            t.subscribe(func(any msg): void {});
        });
    }

    @test
    func subscribeDispatchesMessagesFromPairedSqsQueue(): void {
        let mock = startMockSqs();
        let t = messaging.topic({
            "driver":    "sns",
            "region":    "us-east-1",
            "topicArn":  "arn:aws:sns:us-east-1:123:t",
            "queueUrl":  mock["queueUrl"] as string,
            "accessKey": "k",
            "secretKey": "s"
        });
        list<string> seen = [];
        try {
            t.subscribe(func(any msg): void {
                let m = msg as dict<string, any>;
                seen = seen.push(m["body"] as string);
                /* Throw to exit the consume loop after the first message. */
                throw RuntimeError("STOP");
            });
        } catch (RuntimeError e) {
            /* expected */
        }
        http.shutdown(mock["server"]);
        this.assertEquals(1, seen.length());
        this.assertTrue((seen[0] as string).contains("hello"));
    }
}
