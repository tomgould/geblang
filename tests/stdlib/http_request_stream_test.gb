/**
 * @title http.requestStream client-side response streaming (1.24.0)
 * @summary requestStream returns a StreamResponse whose read() yields the
 * response body line-by-line (null at EOF), for SSE / LLM streaming.
 */
import test;
import http;
import sys;

class HttpRequestStreamTest extends test.Test {

    func newServer(string body): dict<string, any> {
        let server = http.listen("127.0.0.1:0", func(dict<string, any> _): dict<string, any> {
            return {"status": 200, "headers": {"Content-Type": "text/event-stream"}, "body": body};
        });
        let port = (http.serverAddr(server).split(":")[1] as string) as int;
        sys.sleep(20);
        return {"server": server, "port": port};
    }

    @test
    func readsLinesUntilEof(): void {
        let s = this.newServer("alpha\nbeta\ngamma\n");
        let stream = http.requestStream({"method": "GET", "url": "http://127.0.0.1:" + ((s["port"] as int) as string) + "/"});
        this.assertEquals(200, stream.status());
        let lines = [];
        let line = stream.read();
        while (line != null) {
            lines = lines.push(line as string);
            line = stream.read();
        }
        stream.close();
        http.shutdown(s["server"]);
        this.assertEquals(3, lines.length());
        this.assertEquals("alpha", lines[0] as string);
        this.assertEquals("gamma", lines[2] as string);
        this.assertTrue(stream.done());
    }

    @test
    func headersAndCloseWork(): void {
        let s = this.newServer("data: x\n");
        let stream = http.requestStream({"method": "GET", "url": "http://127.0.0.1:" + ((s["port"] as int) as string) + "/"});
        let headers = stream.headers() as dict<string, any>;
        this.assertTrue(headers.contains("Content-Type"));
        stream.close();
        http.shutdown(s["server"]);
        this.assertTrue(stream.done());
        this.assertTrue(stream.read() == null);
    }
}
