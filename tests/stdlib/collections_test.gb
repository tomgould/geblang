/**
 * @title Collections stdlib test
 * @summary list/dict/set operations: sort, unique, map, filter, reduce.
 */
import test;
import collections;

class CollectionsTest extends test.Test {
    @test
    func sortList(): void {
        let xs = [3, 1, 4, 1, 5, 9, 2, 6];
        let sorted = collections.sort(xs);
        this.assertEquals([1, 1, 2, 3, 4, 5, 6, 9], sorted);
    }

    @test
    func unique(): void {
        let xs = [1, 2, 2, 3, 3, 3, 4];
        this.assertEquals([1, 2, 3, 4], collections.unique(xs));
    }

    @test
    func mapFilter(): void {
        let doubled = collections.map([1, 2, 3], func(int n): int { return n * 2; });
        this.assertEquals([2, 4, 6], doubled);
        let evens = collections.filter([1, 2, 3, 4, 5], func(int n): bool { return n % 2 == 0; });
        this.assertEquals([2, 4], evens);
    }

    @test
    func reduce(): void {
        let sum = collections.reduce([1, 2, 3, 4, 5], func(int acc, int n): int { return acc + n; }, 0);
        this.assertEquals(15, sum);
    }

    @test
    func chunk(): void {
        this.assertEquals([[1, 2], [3, 4], [5]], collections.chunk([1, 2, 3, 4, 5], 2));
    }

    @test
    func flatten(): void {
        this.assertEquals([1, 2, 3, 4], collections.flatten([[1, 2], [3, 4]]));
    }

    /* list.sort() is documented as an alias for list.sorted() (the LSP
     * catalog advertises both); guard both names on the method
     * dispatcher so they stay in lockstep. */
    @test
    func listSortMethod(): void {
        let xs = [3, 1, 4, 1, 5, 9, 2, 6];
        this.assertEquals([1, 1, 2, 3, 4, 5, 6, 9], xs.sort());
        this.assertEquals([1, 1, 2, 3, 4, 5, 6, 9], xs.sorted());
    }

    @test
    func listSortWithComparator(): void {
        let xs = [3, 1, 2];
        /* Comparator returns true when `a` should come before `b`. */
        let desc = xs.sort(func(int a, int b): bool { return a > b; });
        this.assertEquals([3, 2, 1], desc);
    }

    @test
    func flatMap(): void {
        let xs = [1, 2, 3];
        this.assertEquals([1, 10, 2, 20, 3, 30],
            xs.flatMap(func(int x): list<int> { return [x, x * 10]; }));
        this.assertEquals([1, 2, 3],
            collections.flatMap(xs, func(int x): list<int> { return [x]; }));
    }

    @test
    func uniqueBy(): void {
        let xs = [{"k": 1}, {"k": 1}, {"k": 2}, {"k": 1}];
        let deduped = xs.uniqueBy(func(dict<string, any> d): any { return d["k"]; });
        this.assertEquals(2, deduped.length());
        this.assertEquals(1, deduped.get(0)["k"]);
        this.assertEquals(2, deduped.get(1)["k"]);
    }

    @test
    func takeWhileAndDropWhile(): void {
        let xs = [1, 2, 3, 4, 1];
        this.assertEquals([1, 2], xs.takeWhile(func(int x): bool { return x < 3; }));
        this.assertEquals([3, 4, 1], xs.dropWhile(func(int x): bool { return x < 3; }));
        this.assertEquals([], xs.takeWhile(func(int x): bool { return x > 100; }));
        this.assertEquals([], xs.dropWhile(func(int x): bool { return x < 100; }));
    }

    @test
    func windowed(): void {
        let xs = [1, 2, 3, 4, 5];
        this.assertEquals([[1, 2], [2, 3], [3, 4], [4, 5]], xs.windowed(2));
        this.assertEquals([[1, 2], [3, 4]], xs.windowed(2, 2));
        this.assertEquals([[1, 2, 3], [3, 4, 5]], xs.windowed(3, 2));
        this.assertEquals([], xs.windowed(6));
    }

    @test
    func unzip(): void {
        let pairs = [[1, "a"], [2, "b"], [3, "c"]];
        let parts = pairs.unzip();
        this.assertEquals([1, 2, 3], parts.get(0));
        this.assertEquals(["a", "b", "c"], parts.get(1));
    }

    @test
    func scan(): void {
        let xs = [1, 2, 3, 4];
        this.assertEquals([0, 1, 3, 6, 10],
            xs.scan(0, func(int acc, int x): int { return acc + x; }));
        list<int> empty = [];
        this.assertEquals([0], empty.scan(0, func(int acc, int x): int { return acc + x; }));
    }
}
