/**
 * @title CSV stdlib test
 * @summary csv.parse, csv.parseDict, csv.stringify (in-memory).
 */
import test;
import csv;

class CSVTest extends test.Test {
    @test
    func parseSimple(): void {
        let rows = csv.parse("a,b,c\n1,2,3\n4,5,6");
        this.assertEquals(3, rows.length);
        this.assertEquals("a", rows[0][0]);
        this.assertEquals("5", rows[2][1]);
    }

    @test
    func parseDictReadsHeaders(): void {
        let rows = csv.parseDict("name,age\nAda,37\nGrace,55");
        this.assertEquals(2, rows.length);
        this.assertEquals("Ada", rows[0]["name"]);
        this.assertEquals("55", rows[1]["age"]);
    }

    @test
    func parseCustomDelimiter(): void {
        let rows = csv.parse("a;b;c\n1;2;3", {"delimiter": ";"});
        this.assertEquals("3", rows[1][2]);
    }

    @test
    func parseTrimSpace(): void {
        let rows = csv.parse("a, b, c\n1, 2, 3", {"trimSpace": true});
        this.assertEquals("b", rows[0][1]);
        this.assertEquals("3", rows[1][2]);
    }

    @test
    func stringifyRoundtrips(): void {
        let original = [["name", "age"], ["Ada", "37"], ["Grace", "55"]];
        let text = csv.stringify(original);
        let parsed = csv.parse(text);
        this.assertEquals(3, parsed.length);
        this.assertEquals("Ada", parsed[1][0]);
    }

    @test
    func emptyInput(): void {
        let rows = csv.parse("");
        this.assertEquals(0, rows.length);
    }

    @test
    func parseDictEmptyAfterHeader(): void {
        let rows = csv.parseDict("name,age");
        this.assertEquals(0, rows.length);
    }

    @test
    func stringifyDictsBasic(): void {
        let records = [{"a": 1, "b": 2}, {"a": 3, "b": 4}];
        let text = csv.stringify(records);
        this.assertEquals("a,b\n1,2\n3,4\n", text);
    }

    @test
    func stringifyDictsMissingKey(): void {
        # second dict lacks "b" -> blank cell
        let records = [{"a": 1, "b": 2}, {"a": 3}];
        let text = csv.stringify(records);
        this.assertEquals("a,b\n1,2\n3,\n", text);
    }

    @test
    func stringifyDictsRoundtrip(): void {
        let records = [{"name": "Ada", "age": "37"}, {"name": "Grace", "age": "55"}];
        let text = csv.stringify(records);
        let back = csv.parseDict(text);
        this.assertEquals(2, back.length);
        this.assertEquals("Ada", back[0]["name"]);
        this.assertEquals("55", back[1]["age"]);
    }

    @test
    func stringifyDictsCustomDelimiter(): void {
        let records = [{"a": 1, "b": 2}];
        let text = csv.stringify(records, {"delimiter": ";"});
        this.assertEquals("a;b\n1;2\n", text);
    }
}
