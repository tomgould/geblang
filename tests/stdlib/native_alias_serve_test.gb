/**
 * @title Native-alias resolution in a served handler
 * @summary A request handler that uses a dual-name stdlib module
 * (async.sync aliased to `native`) must still resolve sync.Mutex when the
 * runtime clones the handler env per request, even with another dual-name
 * native module (profiler) in the import graph.
 *
 * Tagged "integration" so CI can skip on hosts without local
 * port-binding permission.
 */
import test;
import http;
import async.sync as sync;
/* imported last on purpose: profiler wins the global `native` alias slot, so the bug only shows when the cloned env-local canonical is lost */
import profiler;

func handle(dict<string, any> req): dict<string, any> {
    let m = sync.Mutex();
    m.lock();
    m.unlock();
    return {"status": 200, "body": "ok"};
}

class NativeAliasServeTest extends test.Test {
    @tag("integration")
    @test
    func mutexInHandlerResolves(): void {
        let server = http.listen("127.0.0.1:0", handle);
        let resp = http.request("http://" + http.serverAddr(server) + "/").send();
        http.close(server);
        this.assertEquals(200, resp.status());
        this.assertEquals("ok", resp.text());
    }
}
