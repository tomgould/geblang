/**
 * @title Cross-module container mutation (reference semantics)
 * @summary A callee in another module that mutates a dict, list, or nested
 * container argument is visible to the caller, identically on both backends.
 */
import test;
import mutator_donor;

class ContainerMutationTest extends test.Test {
    @test
    func dictMutationPropagates(): void {
        let d = {"value": 1};
        mutator_donor.setFlag(d);
        this.assertTrue(d.contains("flag"));
    }

    @test
    func listMutationPropagates(): void {
        let xs = [1, 2];
        mutator_donor.pushAll(xs);
        this.assertEquals(3, xs.length());
    }

    @test
    func nestedMutationPropagates(): void {
        let d = {"items": [1]};
        mutator_donor.mutateInner(d);
        this.assertEquals(2, (d["items"] as list<any>).length());
    }
}
