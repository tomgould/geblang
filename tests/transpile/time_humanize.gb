import io;
import time;

/* time module: deterministic humanize rendering plus monotonic-non-decreasing and wall-clock-elapsed sign checks (the latter from a fixed past start, so the output is stable across runs and backends). */

let durations = [45, 1500, 2000, 184000, 7500000, 90000000];
for (int d in durations) {
    io.println("${d} -> ${time.humanize(d)}");
}

let a = time.monotonicNs();
let b = time.monotonicNs();
io.println("monotonic-nondecreasing=${b >= a}");

let start = time.now() - 10000;
io.println("elapsed-nonneg=${time.elapsed(start) >= 0}");
