module llm.openai;

import bytes;
import encoding;
import http;
import json;

/**
 * OpenAI Chat Completions / Embeddings / Image APIs.
 * Authenticates via `Authorization: Bearer <apiKey>` on every
 * request. Endpoint defaults to `https://api.openai.com`; override
 * for Azure OpenAI or compatible local stacks via opts.endpoint.
 *
 * Duck-types `llm.Client`; explicit implements is omitted to
 * break a parser-level circular import with the facade module.
 */
export class OpenaiClient {
    string apiKey;
    string endpoint;
    ?string organization;

    func chat(list<dict<string, any>> messages, dict<string, any> opts): dict<string, any> {
        string model = requireString(opts, "model", "llm.openai.chat");
        list<dict<string, any>> body = [];
        if (opts.contains("system")) {
            body = body.push({"role": "system", "content": opts["system"]});
        }
        for (m in messages) {
            body = body.push(openaiToolMessage(m));
        }
        dict<string, any> payload = {"model": model, "messages": body};
        if (opts.contains("tools")) {
            payload["tools"] = openaiTools(opts["tools"] as list<any>);
        }
        copyOpt(opts, payload, "toolChoice", "tool_choice");
        copyOpt(opts, payload, "maxTokens", "max_tokens");
        copyOpt(opts, payload, "temperature", "temperature");
        copyOpt(opts, payload, "topP", "top_p");
        let resp = this.post("/v1/chat/completions", payload);
        let choices = (resp["choices"] ?? []) as list<any>;
        if (choices.length() == 0) {
            throw RuntimeError("llm.openai.chat: response had no choices: " + json.stringify(resp));
        }
        let choice = choices[0] as dict<string, any>;
        let message = choice["message"] as dict<string, any>;
        let usage = (resp["usage"] ?? {}) as dict<string, any>;
        dict<string, any> result = {
            "content":    (message["content"] ?? "") as string,
            "model":      (resp["model"] ?? model) as string,
            "stopReason": (choice["finish_reason"] ?? "") as string,
            "usage":      usageDict(usage, "prompt_tokens", "completion_tokens", "total_tokens")
        };
        if (message.contains("tool_calls") && message["tool_calls"] != null) {
            result["toolCalls"] = parseOpenaiToolCalls(message["tool_calls"] as list<any>);
        }
        return result;
    }

    func chatStream(list<dict<string, any>> messages, dict<string, any> opts, callable callback): dict<string, any> {
        string model = requireString(opts, "model", "llm.openai.chatStream");
        list<dict<string, any>> body = [];
        if (opts.contains("system")) {
            body = body.push({"role": "system", "content": opts["system"]});
        }
        for (m in messages) {
            body = body.push(openaiToolMessage(m));
        }
        dict<string, any> payload = {"model": model, "messages": body, "stream": true};
        if (opts.contains("tools")) {
            payload["tools"] = openaiTools(opts["tools"] as list<any>);
        }
        copyOpt(opts, payload, "maxTokens", "max_tokens");
        copyOpt(opts, payload, "temperature", "temperature");
        copyOpt(opts, payload, "topP", "top_p");
        let stream = http.requestStream({
            "method":  "POST",
            "url":     this.endpoint + "/v1/chat/completions",
            "headers": {"Content-Type": "application/json", "Authorization": "Bearer " + this.apiKey},
            "body":    json.stringify(payload)
        });
        let status = stream.status();
        if (status < 200 || status >= 300) {
            stream.close();
            throw RuntimeError("llm.openai.chatStream: request failed with status " + (status as string));
        }
        string content = "";
        string finishReason = "";
        string respModel = model;
        let line = stream.read();
        while (line != null) {
            string l = line as string;
            if (l.startsWith("data: ")) {
                string data = l.substring(6);
                if (data == "[DONE]") {
                    break;
                }
                let chunk = json.parse(data) as dict<string, any>;
                if (chunk.contains("model")) {
                    respModel = chunk["model"] as string;
                }
                let choices = (chunk["choices"] ?? []) as list<any>;
                if (choices.length() > 0) {
                    let choice = choices[0] as dict<string, any>;
                    let delta = (choice["delta"] ?? {}) as dict<string, any>;
                    if (delta.contains("content") && delta["content"] != null) {
                        string piece = delta["content"] as string;
                        content = content + piece;
                        callback(piece);
                    }
                    if (choice.contains("finish_reason") && choice["finish_reason"] != null) {
                        finishReason = choice["finish_reason"] as string;
                    }
                }
            }
            line = stream.read();
        }
        stream.close();
        return {"content": content, "model": respModel, "stopReason": finishReason, "usage": usageDict({}, "", "", "")};
    }

    func embed(string text, dict<string, any> opts): dict<string, any> {
        string model = requireString(opts, "model", "llm.openai.embed");
        dict<string, any> payload = {"model": model, "input": text};
        copyOpt(opts, payload, "dimensions", "dimensions");
        let resp = this.post("/v1/embeddings", payload);
        let data = (resp["data"] ?? []) as list<any>;
        if (data.length() == 0) {
            throw RuntimeError("llm.openai.embed: response had no embedding: " + json.stringify(resp));
        }
        let first = data[0] as dict<string, any>;
        let usage = (resp["usage"] ?? {}) as dict<string, any>;
        return {
            "vector": first["embedding"],
            "model":  (resp["model"] ?? model) as string,
            "usage":  usageDict(usage, "prompt_tokens", "", "total_tokens")
        };
    }

    func embedBatch(list<string> texts, dict<string, any> opts): dict<string, any> {
        string model = requireString(opts, "model", "llm.openai.embedBatch");
        dict<string, any> payload = {"model": model, "input": texts};
        copyOpt(opts, payload, "dimensions", "dimensions");
        let resp = this.post("/v1/embeddings", payload);
        let data = (resp["data"] ?? []) as list<any>;
        list<any> vectors = [];
        for (entry in data) {
            vectors = vectors.push((entry as dict<string, any>)["embedding"]);
        }
        let usage = (resp["usage"] ?? {}) as dict<string, any>;
        return {
            "vectors": vectors,
            "model":   (resp["model"] ?? model) as string,
            "usage":   usageDict(usage, "prompt_tokens", "", "total_tokens")
        };
    }

    func analyzeImage(bytes image, string prompt, dict<string, any> opts): dict<string, any> {
        string model = requireString(opts, "model", "llm.openai.analyzeImage");
        string mime = opts.contains("mimeType") ? (opts["mimeType"] as string) : "image/png";
        string b64 = encoding.base64Encode(bytes.toString(image));
        list<dict<string, any>> content = [
            {"type": "text", "text": prompt},
            {"type": "image_url", "image_url": {"url": "data:" + mime + ";base64," + b64}}
        ];
        list<dict<string, any>> messages = [{"role": "user", "content": content}];
        dict<string, any> payload = {"model": model, "messages": messages};
        copyOpt(opts, payload, "maxTokens", "max_tokens");
        copyOpt(opts, payload, "temperature", "temperature");
        let resp = this.post("/v1/chat/completions", payload);
        let choices = (resp["choices"] ?? []) as list<any>;
        if (choices.length() == 0) {
            throw RuntimeError("llm.openai.analyzeImage: response had no choices: " + json.stringify(resp));
        }
        let choice = choices[0] as dict<string, any>;
        let message = choice["message"] as dict<string, any>;
        let usage = (resp["usage"] ?? {}) as dict<string, any>;
        return {
            "content":    (message["content"] ?? "") as string,
            "model":      (resp["model"] ?? model) as string,
            "stopReason": (choice["finish_reason"] ?? "") as string,
            "usage":      usageDict(usage, "prompt_tokens", "completion_tokens", "total_tokens")
        };
    }

    func generateImage(string prompt, dict<string, any> opts): dict<string, any> {
        string model = requireString(opts, "model", "llm.openai.generateImage");
        dict<string, any> payload = {
            "model":           model,
            "prompt":          prompt,
            "response_format": "b64_json"
        };
        copyOpt(opts, payload, "size", "size");
        copyOpt(opts, payload, "quality", "quality");
        copyOpt(opts, payload, "n", "n");
        let resp = this.post("/v1/images/generations", payload);
        let data = (resp["data"] ?? []) as list<any>;
        list<dict<string, any>> images = [];
        for (entry in data) {
            let item = entry as dict<string, any>;
            string b64 = (item["b64_json"] ?? "") as string;
            if (b64.isEmpty()) { continue; }
            images = images.push({
                "bytes":  encoding.base64Decode(b64),
                "format": "png"
            });
        }
        return {"images": images, "model": model};
    }

    func post(string path, dict<string, any> payload): dict<string, any> {
        string body = json.stringify(payload);
        dict<string, any> headers = {
            "Content-Type":  "application/json",
            "Authorization": "Bearer " + this.apiKey
        };
        if (this.organization != null) {
            headers["OpenAI-Organization"] = this.organization as string;
        }
        let resp = http.requestWithOptions({
            "method":  "POST",
            "url":     this.endpoint + path,
            "headers": headers,
            "body":    body
        });
        let status = resp["status"] as int;
        if (status < 200 || status >= 300) {
            throw RuntimeError("llm.openai POST " + path + " failed: " +
                (status as string) + " " + (resp["body"] as string));
        }
        return json.parse(resp["body"] as string) as dict<string, any>;
    }

    func models(): list<dict<string, any>> {
        let resp = this.get("/v1/models");
        let data = (resp["data"] ?? []) as list<any>;
        list<dict<string, any>> out = [];
        for (entry in data) {
            let item = entry as dict<string, any>;
            out = out.push({
                "id":      (item["id"] ?? "") as string,
                "ownedBy": (item["owned_by"] ?? "") as string,
                "created": item["created"] ?? 0
            });
        }
        return out;
    }

    func get(string path): dict<string, any> {
        dict<string, any> headers = {"Authorization": "Bearer " + this.apiKey};
        if (this.organization != null) {
            headers["OpenAI-Organization"] = this.organization as string;
        }
        let resp = http.requestWithOptions({"method": "GET", "url": this.endpoint + path, "headers": headers});
        let status = resp["status"] as int;
        if (status < 200 || status >= 300) {
            throw RuntimeError("llm.openai GET " + path + " failed: " +
                (status as string) + " " + (resp["body"] as string));
        }
        return json.parse(resp["body"] as string) as dict<string, any>;
    }
}

/**
 * Build an OpenaiClient from a llm.client options dict.
 * Required: `apiKey`. Optional: `endpoint` (default
 * https://api.openai.com), `organization`.
 */
export func connect(dict<string, any> opts): OpenaiClient {
    if (!opts.contains("apiKey")) {
        throw RuntimeError("llm.openai: opts.apiKey is required");
    }
    let c = OpenaiClient();
    c.apiKey = opts["apiKey"] as string;
    c.endpoint = opts.contains("endpoint") ? (opts["endpoint"] as string) : "https://api.openai.com";
    if (opts.contains("organization")) {
        c.organization = opts["organization"] as string;
    } else {
        c.organization = null;
    }
    return c;
}

/* --- shared helpers (kept in this module rather than the facade
 *     to avoid a cycle; bedrock + anthropic carry their own
 *     copies for the same reason) --- */

func requireString(dict<string, any> opts, string key, string label): string {
    if (!opts.contains(key)) {
        throw RuntimeError(label + ": opts." + key + " is required");
    }
    return opts[key] as string;
}

func copyOpt(dict<string, any> src, dict<string, any> dst, string srcKey, string dstKey): void {
    if (src.contains(srcKey)) {
        dst[dstKey] = src[srcKey];
    }
}

func usageDict(dict<string, any> raw, string inKey, string outKey, string totalKey): dict<string, any> {
    int inputTokens = inKey.isEmpty() ? 0 : ((raw[inKey] ?? 0) as int);
    int outputTokens = outKey.isEmpty() ? 0 : ((raw[outKey] ?? 0) as int);
    int totalTokens = totalKey.isEmpty() ? 0 : ((raw[totalKey] ?? 0) as int);
    return {
        "inputTokens":  inputTokens,
        "outputTokens": outputTokens,
        "totalTokens":  totalTokens
    };
}

func openaiTools(list<any> tools): list<any> {
    list<any> out = [];
    for (t in tools) {
        let tool = t as dict<string, any>;
        out = out.push({"type": "function", "function": {
            "name":        tool["name"],
            "description": (tool["description"] ?? "") as string,
            "parameters":  tool["parameters"] ?? {}
        }});
    }
    return out;
}

func openaiToolMessage(dict<string, any> m): dict<string, any> {
    if (m.contains("toolCalls")) {
        list<any> calls = [];
        for (tc in m["toolCalls"] as list<any>) {
            let call = tc as dict<string, any>;
            calls = calls.push({"id": call["id"], "type": "function", "function": {
                "name":      call["name"],
                "arguments": json.stringify(call["arguments"])
            }});
        }
        return {"role": (m["role"] ?? "assistant") as string, "content": (m["content"] ?? "") as string, "tool_calls": calls};
    }
    if (((m["role"] ?? "") as string) == "tool") {
        return {"role": "tool", "tool_call_id": m["toolCallId"], "content": (m["content"] ?? "") as string};
    }
    return m;
}

func parseOpenaiToolCalls(list<any> tcs): list<any> {
    list<any> out = [];
    for (tc in tcs) {
        let call = tc as dict<string, any>;
        let fn = call["function"] as dict<string, any>;
        string argsStr = (fn["arguments"] ?? "{}") as string;
        out = out.push({"id": call["id"], "name": fn["name"], "arguments": json.parse(argsStr)});
    }
    return out;
}
