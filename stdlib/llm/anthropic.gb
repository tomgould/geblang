module llm.anthropic;

import bytes;
import encoding;
import http;
import json;

/**
 * Anthropic Messages API client. Authenticates via the
 * `x-api-key` header and pins the `anthropic-version` header to
 * a known release.
 *
 * The Anthropic direct API does not expose embeddings or image
 * generation; those methods throw "not supported" so the
 * abstraction can fail fast and let callers route around the
 * limitation (e.g. embed via OpenAI, then chat via Anthropic).
 */
export class AnthropicClient {
    string apiKey;
    string endpoint;
    string apiVersion;

    func chat(list<dict<string, any>> messages, dict<string, any> opts): dict<string, any> {
        return this.runMessages(textMessages(messages), opts);
    }

    func chatStream(list<dict<string, any>> messages, dict<string, any> opts, callable callback): dict<string, any> {
        string model = requireString(opts, "model", "llm.anthropic.chatStream");
        int maxTokens = opts.contains("maxTokens") ? (opts["maxTokens"] as int) : 1024;
        dict<string, any> payload = {"model": model, "messages": textMessages(messages), "max_tokens": maxTokens, "stream": true};
        if (opts.contains("system")) {
            payload["system"] = opts["system"];
        }
        if (opts.contains("temperature")) {
            payload["temperature"] = opts["temperature"];
        }
        if (opts.contains("topP")) {
            payload["top_p"] = opts["topP"];
        }
        if (opts.contains("tools")) {
            payload["tools"] = anthropicTools(opts["tools"] as list<any>);
        }
        let stream = http.requestStream({
            "method":  "POST",
            "url":     this.endpoint + "/v1/messages",
            "headers": {"Content-Type": "application/json", "x-api-key": this.apiKey, "anthropic-version": this.apiVersion},
            "body":    json.stringify(payload)
        });
        let status = stream.status();
        if (status < 200 || status >= 300) {
            stream.close();
            throw RuntimeError("llm.anthropic.chatStream: request failed with status " + (status as string));
        }
        string content = "";
        string stopReason = "";
        let line = stream.read();
        while (line != null) {
            string l = line as string;
            if (l.startsWith("data: ")) {
                let ev = json.parse(l.substring(6)) as dict<string, any>;
                string t = (ev["type"] ?? "") as string;
                if (t == "content_block_delta") {
                    let delta = (ev["delta"] ?? {}) as dict<string, any>;
                    if (((delta["type"] ?? "") as string) == "text_delta") {
                        string piece = (delta["text"] ?? "") as string;
                        content = content + piece;
                        callback(piece);
                    }
                }
                if (t == "message_delta") {
                    let d = (ev["delta"] ?? {}) as dict<string, any>;
                    if (d.contains("stop_reason") && d["stop_reason"] != null) {
                        stopReason = d["stop_reason"] as string;
                    }
                }
            }
            line = stream.read();
        }
        stream.close();
        return {"content": content, "model": model, "stopReason": stopReason, "usage": {"inputTokens": 0, "outputTokens": 0, "totalTokens": 0}};
    }

    func embed(string text, dict<string, any> opts): dict<string, any> {
        throw RuntimeError("llm.anthropic.embed: Anthropic does not provide a public embeddings API; use llm.openai or another provider for vectors.");
    }

    func embedBatch(list<string> texts, dict<string, any> opts): dict<string, any> {
        throw RuntimeError("llm.anthropic.embedBatch: Anthropic does not provide a public embeddings API; use llm.openai or another provider for vectors.");
    }

    func analyzeImage(bytes image, string prompt, dict<string, any> opts): dict<string, any> {
        string mime = opts.contains("mimeType") ? (opts["mimeType"] as string) : "image/png";
        string b64 = encoding.base64Encode(bytes.toString(image));
        list<dict<string, any>> content = [
            {"type": "image", "source": {"type": "base64", "media_type": mime, "data": b64}},
            {"type": "text", "text": prompt}
        ];
        list<dict<string, any>> messages = [{"role": "user", "content": content}];
        return this.runMessages(messages, opts);
    }

    func generateImage(string prompt, dict<string, any> opts): dict<string, any> {
        throw RuntimeError("llm.anthropic.generateImage: Anthropic does not expose an image-generation API.");
    }

    func runMessages(list<dict<string, any>> messages, dict<string, any> opts): dict<string, any> {
        string model = requireString(opts, "model", "llm.anthropic");
        int maxTokens = opts.contains("maxTokens") ? (opts["maxTokens"] as int) : 1024;
        dict<string, any> payload = {"model": model, "messages": messages, "max_tokens": maxTokens};
        if (opts.contains("system")) {
            payload["system"] = opts["system"];
        }
        if (opts.contains("temperature")) {
            payload["temperature"] = opts["temperature"];
        }
        if (opts.contains("topP")) {
            payload["top_p"] = opts["topP"];
        }
        if (opts.contains("tools")) {
            payload["tools"] = anthropicTools(opts["tools"] as list<any>);
        }
        let resp = this.post("/v1/messages", payload);
        let blocks = (resp["content"] ?? []) as list<any>;
        string text = "";
        list<any> toolCalls = [];
        for (b in blocks) {
            let block = b as dict<string, any>;
            let bt = (block["type"] ?? "") as string;
            if (bt == "text") {
                text = text + ((block["text"] ?? "") as string);
            }
            if (bt == "tool_use") {
                toolCalls = toolCalls.push({"id": block["id"], "name": block["name"], "arguments": block["input"] ?? {}});
            }
        }
        let usage = (resp["usage"] ?? {}) as dict<string, any>;
        int inTok = (usage["input_tokens"] ?? 0) as int;
        int outTok = (usage["output_tokens"] ?? 0) as int;
        dict<string, any> result = {
            "content":    text,
            "model":      (resp["model"] ?? model) as string,
            "stopReason": (resp["stop_reason"] ?? "") as string,
            "usage": {
                "inputTokens":  inTok,
                "outputTokens": outTok,
                "totalTokens":  inTok + outTok
            }
        };
        if (toolCalls.length() > 0) {
            result["toolCalls"] = toolCalls;
        }
        return result;
    }

    func post(string path, dict<string, any> payload): dict<string, any> {
        string body = json.stringify(payload);
        let resp = http.requestWithOptions({
            "method":  "POST",
            "url":     this.endpoint + path,
            "headers": {
                "Content-Type":      "application/json",
                "x-api-key":         this.apiKey,
                "anthropic-version": this.apiVersion
            },
            "body": body
        });
        let status = resp["status"] as int;
        if (status < 200 || status >= 300) {
            throw RuntimeError("llm.anthropic POST " + path + " failed: " +
                (status as string) + " " + (resp["body"] as string));
        }
        return json.parse(resp["body"] as string) as dict<string, any>;
    }

    func models(): list<dict<string, any>> {
        let resp = this.get("/v1/models");
        let data = (resp["data"] ?? []) as list<any>;
        list<dict<string, any>> out = [];
        for (entry in data) {
            let item = entry as dict<string, any>;
            out = out.push({
                "id":          (item["id"] ?? "") as string,
                "displayName": (item["display_name"] ?? "") as string
            });
        }
        return out;
    }

    func get(string path): dict<string, any> {
        let resp = http.requestWithOptions({
            "method":  "GET",
            "url":     this.endpoint + path,
            "headers": {
                "x-api-key":         this.apiKey,
                "anthropic-version": this.apiVersion
            }
        });
        let status = resp["status"] as int;
        if (status < 200 || status >= 300) {
            throw RuntimeError("llm.anthropic GET " + path + " failed: " +
                (status as string) + " " + (resp["body"] as string));
        }
        return json.parse(resp["body"] as string) as dict<string, any>;
    }
}

/**
 * Build an AnthropicClient. Required: `apiKey`. Optional:
 * `endpoint` (default https://api.anthropic.com), `apiVersion`
 * (default 2023-06-01, the stable Messages API release).
 */
export func connect(dict<string, any> opts): AnthropicClient {
    if (!opts.contains("apiKey")) {
        throw RuntimeError("llm.anthropic: opts.apiKey is required");
    }
    let c = AnthropicClient();
    c.apiKey = opts["apiKey"] as string;
    c.endpoint = opts.contains("endpoint") ? (opts["endpoint"] as string) : "https://api.anthropic.com";
    c.apiVersion = opts.contains("apiVersion") ? (opts["apiVersion"] as string) : "2023-06-01";
    return c;
}

/* --- helpers --- */

func textMessages(list<dict<string, any>> messages): list<dict<string, any>> {
    /* Anthropic's Messages API rejects `role: "system"` inside the
     * messages array; system prompts go on the top-level `system`
     * field. Filter them out and let `runMessages` route them via
     * opts.system when provided. The caller is responsible for
     * folding any system message into opts; we just defensively
     * drop them here. */
    list<dict<string, any>> out = [];
    for (m in messages) {
        if ((m["role"] as string) != "system") {
            out = out.push(anthropicToolMessage(m));
        }
    }
    return out;
}

func anthropicTools(list<any> tools): list<any> {
    list<any> out = [];
    for (t in tools) {
        let tool = t as dict<string, any>;
        out = out.push({"name": tool["name"], "description": (tool["description"] ?? "") as string, "input_schema": tool["parameters"] ?? {}});
    }
    return out;
}

func anthropicToolMessage(dict<string, any> m): dict<string, any> {
    if (m.contains("toolCalls")) {
        list<any> content = [];
        string text = (m["content"] ?? "") as string;
        if (!text.isEmpty()) {
            content = content.push({"type": "text", "text": text});
        }
        for (tc in m["toolCalls"] as list<any>) {
            let call = tc as dict<string, any>;
            content = content.push({"type": "tool_use", "id": call["id"], "name": call["name"], "input": call["arguments"] ?? {}});
        }
        return {"role": "assistant", "content": content};
    }
    if (((m["role"] ?? "") as string) == "tool") {
        return {"role": "user", "content": [{"type": "tool_result", "tool_use_id": m["toolCallId"], "content": (m["content"] ?? "") as string}]};
    }
    return m;
}

func requireString(dict<string, any> opts, string key, string label): string {
    if (!opts.contains(key)) {
        throw RuntimeError(label + ": opts." + key + " is required");
    }
    return opts[key] as string;
}
