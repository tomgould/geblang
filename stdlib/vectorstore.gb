module vectorstore;

import async.sync as sync;
import binary;
import json;
import re;
import vecmath;
import hnsw;

/**
 * In-memory and persistent vector stores for embeddings, with brute-force
 * similarity search. The foundation for retrieval-augmented generation (see
 * the `rag` module).
 *
 * ```gb
 * import vectorstore;
 *
 * let store = vectorstore.MemoryVectorStore();
 * store.add("a", [0.1, 0.2, 0.9], {"text": "about cats"});
 * store.add("b", [0.9, 0.1, 0.1], {"text": "about cars"});
 * let hits = store.search([0.1, 0.2, 0.8], 1);   // -> [SearchHit for "a"]
 * io.println(hits[0].record.metadata["text"]);
 * ```
 *
 * Metric is cosine by default; pass "dot" or "euclidean" to the constructor.
 * All scores follow "higher = closer".
 */
export class VectorRecord {
    string id;
    list<any> vector;
    dict<string, any> metadata;

    func VectorRecord(string id, list<any> vector, dict<string, any> metadata) {
        this.id = id;
        this.vector = vector;
        this.metadata = metadata;
    }
}

export class SearchHit {
    VectorRecord record;
    float score;

    func SearchHit(VectorRecord record, float score) {
        this.record = record;
        this.score = score;
    }
}

/** A store of id-keyed vectors supporting nearest-neighbour search. */
export interface VectorStore {
    func add(string id, list<any> vector, dict<string, any> metadata): void;
    func addAll(list<VectorRecord> records): void;
    func get(string id): ?VectorRecord;
    func delete(string id): bool;
    func search(list<any> query, int k): list<SearchHit>;
    func searchWhere(list<any> query, int k, callable filter): list<SearchHit>;
    func searchFilter(list<any> query, int k, dict<string, any> criteria): list<SearchHit>;
    func count(): int;
    func clear(): void;
}

/**
 * Brute-force in-memory store. O(n) per search; ideal up to ~1e4-1e5 vectors.
 * Mutations and the search snapshot are guarded by a mutex, so a single shared
 * store is safe under concurrent requests.
 */
export class MemoryVectorStore implements VectorStore {
    dict<string, any> _records;
    string _metric;
    sync.Mutex _lock;

    func MemoryVectorStore(string metric = "cosine") {
        if (metric != "cosine" && metric != "dot" && metric != "euclidean") {
            throw ValueError("MemoryVectorStore: unknown metric '" + metric + "'");
        }
        this._records = {};
        this._metric = metric;
        this._lock = sync.Mutex();
    }

    func add(string id, list<any> vector, dict<string, any> metadata): void {
        let blob = encodeVector(vector);
        this._lock.lock();
        try {
            this._records[id] = {"blob": blob, "metadata": metadata};
        } finally {
            this._lock.unlock();
        }
    }

    func addAll(list<VectorRecord> records): void {
        this._lock.lock();
        try {
            for (rec in records) {
                let r = rec as VectorRecord;
                this._records[r.id] = {"blob": encodeVector(r.vector), "metadata": r.metadata};
            }
        } finally {
            this._lock.unlock();
        }
    }

    func get(string id): ?VectorRecord {
        this._lock.lock();
        try {
            if (this._records.contains(id)) {
                let rec = this._records[id] as dict<string, any>;
                return VectorRecord(id, decodeVector(rec["blob"] as bytes), rec["metadata"] as dict<string, any>);
            }
            return null;
        } finally {
            this._lock.unlock();
        }
    }

    func delete(string id): bool {
        this._lock.lock();
        try {
            if (!this._records.contains(id)) {
                return false;
            }
            this._records.delete(id);
            return true;
        } finally {
            this._lock.unlock();
        }
    }

    func count(): int {
        this._lock.lock();
        try {
            return this._records.keys().length();
        } finally {
            this._lock.unlock();
        }
    }

    func clear(): void {
        this._lock.lock();
        try {
            this._records = {};
        } finally {
            this._lock.unlock();
        }
    }

    func search(list<any> query, int k): list<SearchHit> {
        let ids = [];
        let blobs = [];
        let metas = [];
        this._lock.lock();
        try {
            for (id in this._records.keys()) {
                let rec = this._records[id] as dict<string, any>;
                ids = ids.push(id);
                blobs = blobs.push(rec["blob"]);
                metas = metas.push(rec["metadata"]);
            }
        } finally {
            this._lock.unlock();
        }
        return rankHitsNative(ids, blobs, metas, query, this._metric, k);
    }

    func searchWhere(list<any> query, int k, callable filter): list<SearchHit> {
        /* Snapshot under the lock, then filter + rank unlocked. */
        let ids = [];
        let blobs = [];
        let metas = [];
        this._lock.lock();
        try {
            for (id in this._records.keys()) {
                let rec = this._records[id] as dict<string, any>;
                ids = ids.push(id);
                blobs = blobs.push(rec["blob"]);
                metas = metas.push(rec["metadata"]);
            }
        } finally {
            this._lock.unlock();
        }
        return rankFiltered(ids, blobs, metas, query, this._metric, k, filter);
    }

    func searchFilter(list<any> query, int k, dict<string, any> criteria): list<SearchHit> {
        return this.searchWhere(query, k, func(any rec): bool {
            return matchesCriteria((rec as VectorRecord).metadata, criteria);
        });
    }
}

/**
 * Persistent store backed by a SQL table via the `db` module. Vectors are
 * stored as little-endian float32 BLOBs and metadata as JSON text; search loads
 * the rows and ranks them in memory (no SQL-side ANN). The table is created on
 * construction if absent. add() upserts by id.
 *
 * ```gb
 * import db; import vectorstore;
 * let conn = db.connect("sqlite", "vectors.db");
 * let store = vectorstore.SqliteVectorStore(conn);
 * store.add("doc-1", embedding, {"text": "..."});
 * let hits = store.search(queryVector, 5);
 * ```
 */
export class SqliteVectorStore implements VectorStore {
    any _conn;
    string _table;
    string _metric;

    func SqliteVectorStore(any conn, string table = "vectors", string metric = "cosine") {
        if (metric != "cosine" && metric != "dot" && metric != "euclidean") {
            throw ValueError("SqliteVectorStore: unknown metric '" + metric + "'");
        }
        if (!re.test("^[A-Za-z_][A-Za-z0-9_]*$", table)) {
            throw ValueError("SqliteVectorStore: unsafe table name '" + table + "'");
        }
        this._conn = conn;
        this._table = table;
        this._metric = metric;
        conn.exec("CREATE TABLE IF NOT EXISTS " + table
            + " (id TEXT PRIMARY KEY, vector BLOB NOT NULL, metadata TEXT NOT NULL)");
    }

    func add(string id, list<any> vector, dict<string, any> metadata): void {
        this._conn.exec("INSERT OR REPLACE INTO " + this._table
            + " (id, vector, metadata) VALUES (?, ?, ?)",
            id, encodeVector(vector), json.stringify(metadata));
    }

    func addAll(list<VectorRecord> records): void {
        for (rec in records) {
            let r = rec as VectorRecord;
            this.add(r.id, r.vector, r.metadata);
        }
    }

    func get(string id): ?VectorRecord {
        let rows = this._conn.query("SELECT vector, metadata FROM " + this._table
            + " WHERE id = ?", id).all();
        if (rows.length() == 0) {
            return null;
        }
        return rowToRecord(id, rows[0]);
    }

    func delete(string id): bool {
        let r = this._conn.exec("DELETE FROM " + this._table + " WHERE id = ?", id);
        return (r["rowsAffected"] as int) > 0;
    }

    func count(): int {
        let rows = this._conn.query("SELECT COUNT(*) AS c FROM " + this._table).all();
        return rows[0]["c"] as int;
    }

    func clear(): void {
        this._conn.exec("DELETE FROM " + this._table);
    }

    func search(list<any> query, int k): list<SearchHit> {
        let rows = this._conn.query("SELECT id, vector, metadata FROM " + this._table).all();
        let ids = [];
        let blobs = [];
        let metas = [];
        for (row in rows) {
            let r = row as dict<string, any>;
            ids = ids.push(r["id"]);
            blobs = blobs.push(r["vector"]);
            metas = metas.push(json.parse(r["metadata"] as string));
        }
        return rankHitsNative(ids, blobs, metas, query, this._metric, k);
    }

    func searchWhere(list<any> query, int k, callable filter): list<SearchHit> {
        let rows = this._conn.query("SELECT id, vector, metadata FROM " + this._table).all();
        let ids = [];
        let blobs = [];
        let metas = [];
        for (row in rows) {
            let r = row as dict<string, any>;
            ids = ids.push(r["id"]);
            blobs = blobs.push(r["vector"]);
            metas = metas.push(json.parse(r["metadata"] as string));
        }
        return rankFiltered(ids, blobs, metas, query, this._metric, k, filter);
    }

    func searchFilter(list<any> query, int k, dict<string, any> criteria): list<SearchHit> {
        return this.searchWhere(query, k, func(any rec): bool {
            return matchesCriteria((rec as VectorRecord).metadata, criteria);
        });
    }
}

/**
 * Persistent store backed by Postgres + the pgvector extension via the `db`
 * module. Uses a typed vector(D) column, a metric-matched HNSW index, jsonb
 * metadata, and index-using ANN queries (the same shape as idiomatic pgvector
 * usage elsewhere). The extension, table, and index are created on construction.
 * add() upserts by id.
 *
 * ```gb
 * import db; import vectorstore;
 * let conn  = db.connect("postgres", dsn);
 * let store = vectorstore.PgVectorStore(conn, "items", 1536);
 * store.add("doc-1", embedding, {"source": "handbook"});
 * let hits = store.searchFilter(queryVector, 5, {"source": "handbook"});
 * ```
 *
 * The pgvector value is bound in its text form with CAST(? AS vector); metadata
 * filters push down server-side as jsonb containment / range predicates.
 */
export class PgVectorStore implements VectorStore {
    any _conn;
    string _table;
    int _dim;
    string _metric;

    func PgVectorStore(any conn, string table = "vectors", int dimension = 0, string metric = "cosine") {
        if (metric != "cosine" && metric != "dot" && metric != "euclidean") {
            throw ValueError("PgVectorStore: unknown metric '" + metric + "'");
        }
        if (dimension <= 0) {
            throw ValueError("PgVectorStore: dimension must be a positive integer");
        }
        if (!re.test("^[A-Za-z_][A-Za-z0-9_]*$", table)) {
            throw ValueError("PgVectorStore: unsafe table name '" + table + "'");
        }
        this._conn = conn;
        this._table = table;
        this._dim = dimension;
        this._metric = metric;
        conn.exec("CREATE EXTENSION IF NOT EXISTS vector");
        conn.exec("CREATE TABLE IF NOT EXISTS " + table + " (id text PRIMARY KEY, embedding vector("
            + (dimension as string) + ") NOT NULL, metadata jsonb NOT NULL)");
        conn.exec("CREATE INDEX IF NOT EXISTS " + table + "_embedding_idx ON " + table
            + " USING hnsw (embedding " + pgOpsClass(metric) + ")");
    }

    func add(string id, list<any> vector, dict<string, any> metadata): void {
        this._conn.exec("INSERT INTO " + this._table
            + " (id, embedding, metadata) VALUES (?, CAST(? AS vector), CAST(? AS jsonb))"
            + " ON CONFLICT (id) DO UPDATE SET embedding = EXCLUDED.embedding, metadata = EXCLUDED.metadata",
            id, vectorToPgText(vector), json.stringify(metadata));
    }

    func addAll(list<VectorRecord> records): void {
        for (rec in records) {
            let r = rec as VectorRecord;
            this.add(r.id, r.vector, r.metadata);
        }
    }

    func get(string id): ?VectorRecord {
        let rows = this._conn.query("SELECT embedding, metadata FROM " + this._table + " WHERE id = ?", id).all();
        if (rows.length() == 0) {
            return null;
        }
        let r = rows[0] as dict<string, any>;
        return VectorRecord(id, json.parse(r["embedding"] as string) as list<any>,
            json.parse(r["metadata"] as string) as dict<string, any>);
    }

    func delete(string id): bool {
        let r = this._conn.exec("DELETE FROM " + this._table + " WHERE id = ?", id);
        return (r["rowsAffected"] as int) > 0;
    }

    func count(): int {
        let rows = this._conn.query("SELECT COUNT(*) AS c FROM " + this._table).all();
        return rows[0]["c"] as int;
    }

    func clear(): void {
        this._conn.exec("DELETE FROM " + this._table);
    }

    func search(list<any> query, int k): list<SearchHit> {
        return this.runSearch(query, k, "", []);
    }

    func searchFilter(list<any> query, int k, dict<string, any> criteria): list<SearchHit> {
        let w = pgWhere(criteria);
        return this.runSearch(query, k, w["sql"] as string, w["params"] as list<any>);
    }

    func searchWhere(list<any> query, int k, callable filter): list<SearchHit> {
        /* An arbitrary callable cannot be pushed to SQL: rank all by distance
         * (index-ordered), filter client-side, take k. Prefer searchFilter for
         * scale. */
        let out = [];
        for (h in this.runSearch(query, -1, "", [])) {
            if (out.length() >= k) {
                break;
            }
            if (filter((h as SearchHit).record)) {
                out = out.push(h);
            }
        }
        return out;
    }

    func runSearch(list<any> query, int k, string whereSql, list<any> whereParams): list<SearchHit> {
        let qtext = vectorToPgText(query);
        let params = [qtext];
        for (p in whereParams) {
            params = params.push(p);
        }
        params = params.push(qtext);
        string sql = "SELECT id, embedding, metadata, " + pgScoreExpr(this._metric)
            + " AS score FROM " + this._table;
        if (whereSql != "") {
            sql = sql + " WHERE " + whereSql;
        }
        sql = sql + " ORDER BY embedding " + pgOperator(this._metric) + " CAST(? AS vector)";
        if (k >= 0) {
            sql = sql + " LIMIT ?";
            params = params.push(k);
        }
        let out = [];
        for (row in this._conn.query(sql, ...params).all()) {
            let r = row as dict<string, any>;
            let rec = VectorRecord(r["id"] as string, json.parse(r["embedding"] as string) as list<any>,
                json.parse(r["metadata"] as string) as dict<string, any>);
            out = out.push(SearchHit(rec, r["score"] as float));
        }
        return out;
    }
}

/**
 * In-process approximate-nearest-neighbour store backed by an HNSW index (the
 * native `hnsw` module). Sublinear search with no external service; ideal when
 * the in-memory brute-force store is too slow but a database is unwanted.
 * Metadata is held in Geblang; the index holds the vectors. add() upserts by id.
 *
 * ```gb
 * import vectorstore;
 * let store = vectorstore.HnswVectorStore("cosine");
 * store.add("doc-1", embedding, {"text": "..."});
 * let hits = store.search(queryVector, 5);
 * ```
 *
 * Results are approximate: tune recall via the constructor's `m` (graph degree)
 * and `efSearch` (search breadth). Filtered searches over-fetch then filter, so
 * a very selective filter may return fewer than k hits.
 */
export class HnswVectorStore implements VectorStore {
    any _index;
    string _metric;
    dict<string, any> _meta;
    sync.Mutex _lock;

    func HnswVectorStore(string metric = "cosine", int m = 16, int efSearch = 20) {
        if (metric != "cosine" && metric != "dot" && metric != "euclidean") {
            throw ValueError("HnswVectorStore: unknown metric '" + metric + "'");
        }
        this._index = hnsw.new(metric, m, efSearch);
        this._metric = metric;
        this._meta = {};
        this._lock = sync.Mutex();
    }

    func add(string id, list<any> vector, dict<string, any> metadata): void {
        this._lock.lock();
        try {
            hnsw.add(this._index, id, vector);
            this._meta[id] = metadata;
        } finally {
            this._lock.unlock();
        }
    }

    func addAll(list<VectorRecord> records): void {
        for (rec in records) {
            let r = rec as VectorRecord;
            this.add(r.id, r.vector, r.metadata);
        }
    }

    func get(string id): ?VectorRecord {
        this._lock.lock();
        try {
            let vec = hnsw.get(this._index, id);
            if (vec == null) {
                return null;
            }
            return VectorRecord(id, vec as list<any>, (this._meta[id] ?? {}) as dict<string, any>);
        } finally {
            this._lock.unlock();
        }
    }

    func delete(string id): bool {
        this._lock.lock();
        try {
            let removed = hnsw.delete(this._index, id);
            if (removed) {
                this._meta.delete(id);
            }
            return removed;
        } finally {
            this._lock.unlock();
        }
    }

    func count(): int {
        this._lock.lock();
        try {
            return hnsw.count(this._index);
        } finally {
            this._lock.unlock();
        }
    }

    func clear(): void {
        this._lock.lock();
        try {
            hnsw.clear(this._index);
            this._meta = {};
        } finally {
            this._lock.unlock();
        }
    }

    func search(list<any> query, int k): list<SearchHit> {
        this._lock.lock();
        try {
            let out = [];
            for (h in hnsw.search(this._index, query, k)) {
                out = out.push(this.toHit(h as dict<string, any>));
            }
            return out;
        } finally {
            this._lock.unlock();
        }
    }

    func searchWhere(list<any> query, int k, callable filter): list<SearchHit> {
        return this.filteredSearch(query, k, func(any id, any vec, any meta): bool {
            return filter(VectorRecord(id as string, vec as list<any>, meta as dict<string, any>));
        });
    }

    func searchFilter(list<any> query, int k, dict<string, any> criteria): list<SearchHit> {
        return this.filteredSearch(query, k, func(any id, any vec, any meta): bool {
            return matchesCriteria(meta as dict<string, any>, criteria);
        });
    }

    /* Over-fetch from the index, then keep the first k results whose
     * (id, vector, metadata) passes the predicate. */
    func filteredSearch(list<any> query, int k, callable keep): list<SearchHit> {
        this._lock.lock();
        try {
            int fetch = k * 8;
            int total = hnsw.count(this._index);
            if (fetch > total) {
                fetch = total;
            }
            let out = [];
            for (h in hnsw.search(this._index, query, fetch)) {
                if (out.length() >= k) {
                    break;
                }
                let hh = h as dict<string, any>;
                let meta = (this._meta[hh["id"] as string] ?? {}) as dict<string, any>;
                if (keep(hh["id"], hh["vector"], meta)) {
                    out = out.push(this.toHit(hh));
                }
            }
            return out;
        } finally {
            this._lock.unlock();
        }
    }

    func toHit(dict<string, any> h): SearchHit {
        let id = h["id"] as string;
        let rec = VectorRecord(id, h["vector"] as list<any>, (this._meta[id] ?? {}) as dict<string, any>);
        return SearchHit(rec, h["score"] as float);
    }
}

/** Native-kernel top-k over packed float32 blobs aligned with ids and metadata. */
func rankHitsNative(list<string> ids, list<any> blobs, list<any> metas, list<any> query, string metric, int k): list<SearchHit> {
    let out = [];
    for (r in vecmath.topK(blobs, query, k, metric)) {
        let rr = r as dict<string, any>;
        int i = rr["index"] as int;
        let rec = VectorRecord(ids[i] as string, decodeVector(blobs[i] as bytes), metas[i] as dict<string, any>);
        out = out.push(SearchHit(rec, rr["score"] as float));
    }
    return out;
}

/** Applies the metadata filter (which receives a decoded VectorRecord), then ranks. */
func rankFiltered(list<string> ids, list<any> blobs, list<any> metas, list<any> query, string metric, int k, callable filter): list<SearchHit> {
    let fids = [];
    let fblobs = [];
    let fmetas = [];
    for (i in 0..<ids.length()) {
        let rec = VectorRecord(ids[i] as string, decodeVector(blobs[i] as bytes), metas[i] as dict<string, any>);
        if (filter(rec)) {
            fids = fids.push(ids[i]);
            fblobs = fblobs.push(blobs[i]);
            fmetas = fmetas.push(metas[i]);
        }
    }
    return rankHitsNative(fids, fblobs, fmetas, query, metric, k);
}

func encodeVector(list<any> vector): bytes {
    let floats = [];
    for (x in vector) {
        floats = floats.push(x as float);
    }
    return binary.pack("<" + (vector.length() as string) + "f", ...floats);
}

func decodeVector(bytes b): list<any> {
    int n = b.length() // 4;
    if (n == 0) {
        return [];
    }
    return binary.unpack("<" + (n as string) + "f", b);
}

func rowToRecord(string id, dict<string, any> row): VectorRecord {
    return VectorRecord(id, decodeVector(row["vector"] as bytes),
        json.parse(row["metadata"] as string) as dict<string, any>);
}

/** Similarity score (higher = closer) between two vectors for the given metric. */
export func score(string metric, list<any> a, list<any> b): float {
    return vecmath.score(metric, a, b);
}

/**
 * Tests a metadata dict against a criteria dict. A scalar value means equality;
 * a nested operator dict supports eq/ne/gt/gte/lt/lte/in. Multiple keys AND.
 */
func matchesCriteria(dict<string, any> meta, dict<string, any> criteria): bool {
    for (field in criteria.keys()) {
        let cond = criteria[field];
        let actual = meta[field] ?? null;
        if ("${typeof(cond)}" == "dict") {
            let ops = cond as dict<string, any>;
            for (op in ops.keys()) {
                if (!matchOp(op as string, actual, ops[op])) {
                    return false;
                }
            }
        } else {
            if (actual != cond) {
                return false;
            }
        }
    }
    return true;
}

func matchOp(string op, any actual, any val): bool {
    if (op == "in") {
        return (val as list<any>).contains(actual);
    }
    if (actual == null) {
        return false;
    }
    if (op == "eq") { return actual == val; }
    if (op == "ne") { return actual != val; }
    if (op == "gt") { return actual > val; }
    if (op == "gte") { return actual >= val; }
    if (op == "lt") { return actual < val; }
    if (op == "lte") { return actual <= val; }
    throw ValueError("vectorstore: unknown filter operator '" + op + "'");
}

func vectorToPgText(list<any> vector): string {
    let parts = [];
    for (x in vector) {
        parts = parts.push((x as float) as string);
    }
    return "[" + parts.join(",") + "]";
}

func pgOpsClass(string metric): string {
    if (metric == "dot") { return "vector_ip_ops"; }
    if (metric == "euclidean") { return "vector_l2_ops"; }
    return "vector_cosine_ops";
}

func pgOperator(string metric): string {
    if (metric == "dot") { return "<#>"; }
    if (metric == "euclidean") { return "<->"; }
    return "<=>";
}

func pgScoreExpr(string metric): string {
    /* map the distance operator back to a "higher = closer" score */
    if (metric == "dot") { return "-(embedding <#> CAST(? AS vector))"; }
    if (metric == "euclidean") { return "-(embedding <-> CAST(? AS vector))"; }
    return "1 - (embedding <=> CAST(? AS vector))";
}

func pgCmpOp(string op): string {
    if (op == "gt") { return ">"; }
    if (op == "gte") { return ">="; }
    if (op == "lt") { return "<"; }
    if (op == "lte") { return "<="; }
    throw ValueError("vectorstore: unsupported comparison operator '" + op + "'");
}

/** Translates a criteria dict into a parameterized SQL WHERE over jsonb metadata. */
func pgWhere(dict<string, any> criteria): dict<string, any> {
    let clauses = [];
    let params = [];
    for (field in criteria.keys()) {
        let cond = criteria[field];
        if ("${typeof(cond)}" == "dict") {
            let ops = cond as dict<string, any>;
            for (op in ops.keys()) {
                let val = ops[op];
                if (op == "eq" || op == "ne") {
                    let obj = {};
                    obj[field] = val;
                    if (op == "eq") {
                        clauses = clauses.push("metadata @> CAST(? AS jsonb)");
                    } else {
                        clauses = clauses.push("NOT (metadata @> CAST(? AS jsonb))");
                    }
                    params = params.push(json.stringify(obj));
                } else if (op == "in") {
                    let ors = [];
                    for (v in (val as list<any>)) {
                        let obj = {};
                        obj[field] = v;
                        ors = ors.push("metadata @> CAST(? AS jsonb)");
                        params = params.push(json.stringify(obj));
                    }
                    clauses = clauses.push("(" + ors.join(" OR ") + ")");
                } else {
                    clauses = clauses.push("CAST(metadata->>? AS float8) " + pgCmpOp(op as string) + " ?");
                    params = params.push(field);
                    params = params.push(val as float);
                }
            }
        } else {
            let obj = {};
            obj[field] = cond;
            clauses = clauses.push("metadata @> CAST(? AS jsonb)");
            params = params.push(json.stringify(obj));
        }
    }
    return {"sql": clauses.join(" AND "), "params": params};
}
