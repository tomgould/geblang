module result;

## A value that is either a success (ok = true, value set) or a failure (ok = false, error set).
export class Result<T, E> {
    bool ok;
    ?T value;
    ?E error;

    func Result(bool ok, ?T value, ?E error) {
        this.ok = ok;
        this.value = value;
        this.error = error;
    }

    ## Returns true when this result represents success.
    func isOk(): bool {
        return this.ok;
    }

    ## Returns true when this result represents failure.
    func isErr(): bool {
        return !this.ok;
    }

    ## Returns the success value, or throws if this is an error.
    func unwrap(): T {
        if (!this.ok) {
            throw ValueError("Result.unwrap called on error result");
        }
        return this.value;
    }

    ## Returns the success value, or fallback if this is an error.
    func unwrapOr(T fallback): T {
        if (!this.ok) {
            return fallback;
        }
        return this.value;
    }

    ## Returns the error value, or throws if this is a success.
    func unwrapErr(): E {
        if (this.ok) {
            throw ValueError("Result.unwrapErr called on ok result");
        }
        return this.error;
    }
}

## Returns a success Result wrapping value.
export func ok<T, E>(T value): Result<T, E> {
    return Result<T, E>(true, value, null);
}

## Returns a failure Result wrapping error.
export func err<T, E>(E error): Result<T, E> {
    return Result<T, E>(false, null, error);
}
