{
    "Function declaration": {
        "prefix": "func",
        "body": [
            "func ${1:name}(${2:params}): ${3:void} {",
            "\t$0",
            "}"
        ],
        "description": "Function declaration"
    },
    "Async function": {
        "prefix": "asyncfunc",
        "body": [
            "async func ${1:name}(${2:params}): ${3:any} {",
            "\t$0",
            "}"
        ],
        "description": "Async function declaration"
    },
    "Generator function": {
        "prefix": "genfunc",
        "body": [
            "func ${1:name}(${2:params}): generator<${3:any}> {",
            "\tfor (${4:n} in ${5:source}) {",
            "\t\tyield ${4:n};",
            "\t}",
            "}"
        ],
        "description": "Generator function with yield"
    },
    "Class declaration": {
        "prefix": "class",
        "body": [
            "class ${1:Name} {",
            "\t${2:string} ${3:field};",
            "",
            "\tfunc ${1:Name}(${2:string} ${3:field}) {",
            "\t\tthis.${3:field} = ${3:field};",
            "\t}",
            "$0",
            "}"
        ],
        "description": "Class with constructor"
    },
    "Class extending": {
        "prefix": "classex",
        "body": [
            "class ${1:Name} extends ${2:Parent} {",
            "\tfunc ${1:Name}(${3:args}) {",
            "\t\tparent(${3:args});",
            "\t}",
            "$0",
            "}"
        ],
        "description": "Class extending a parent"
    },
    "Interface declaration": {
        "prefix": "interface",
        "body": [
            "interface ${1:Name} {",
            "\tfunc ${2:method}(${3:params}): ${4:void};",
            "$0",
            "}"
        ],
        "description": "Interface declaration"
    },
    "Enum declaration": {
        "prefix": "enum",
        "body": [
            "enum ${1:Name} {",
            "\t${2:VARIANT_ONE},",
            "\t${3:VARIANT_TWO}",
            "$0",
            "}"
        ],
        "description": "Enum declaration"
    },
    "Match statement": {
        "prefix": "match",
        "body": [
            "match (${1:value}) {",
            "\tcase ${2:pattern} => {",
            "\t\t$0",
            "\t}",
            "\tdefault => {",
            "\t}",
            "}"
        ],
        "description": "Match statement"
    },
    "Try / catch / finally": {
        "prefix": "try",
        "body": [
            "try {",
            "\t$0",
            "} catch (${1:Error} e) {",
            "\t",
            "} finally {",
            "\t",
            "}"
        ],
        "description": "Try / catch / finally"
    },
    "Throw error": {
        "prefix": "throw",
        "body": [
            "throw ${1:Error}(\"${2:message}\");"
        ],
        "description": "Throw an error"
    },
    "For-in loop": {
        "prefix": "forin",
        "body": [
            "for (${1:item} in ${2:items}) {",
            "\t$0",
            "}"
        ],
        "description": "For-in loop"
    },
    "C-style for loop": {
        "prefix": "for",
        "body": [
            "for (int ${1:i} = 0; ${1:i} < ${2:n}; ${1:i}++) {",
            "\t$0",
            "}"
        ],
        "description": "C-style for loop"
    },
    "While loop": {
        "prefix": "while",
        "body": [
            "while (${1:condition}) {",
            "\t$0",
            "}"
        ],
        "description": "While loop"
    },
    "Test class": {
        "prefix": "testclass",
        "body": [
            "import test;",
            "",
            "class ${1:Name}Test extends test.Test {",
            "\t@test",
            "\tfunc ${2:behaviour}(): void {",
            "\t\tthis.assertEquals(${3:expected}, ${4:actual});",
            "\t}",
            "$0",
            "}"
        ],
        "description": "Test class with @test method"
    },
    "@test method": {
        "prefix": "test",
        "body": [
            "@test",
            "func ${1:behaviour}(): void {",
            "\tthis.assertEquals(${2:expected}, ${3:actual});",
            "$0",
            "}"
        ],
        "description": "@test-decorated method"
    },
    "@immutable class": {
        "prefix": "immutable",
        "body": [
            "@immutable",
            "class ${1:Name} {",
            "\t${2:string} ${3:field};",
            "",
            "\tfunc ${1:Name}(${2:string} ${3:field}) {",
            "\t\tthis.${3:field} = ${3:field};",
            "\t}",
            "$0",
            "}"
        ],
        "description": "@immutable class"
    },
    "Defer call": {
        "prefix": "defer",
        "body": [
            "defer ${1:cleanup}();"
        ],
        "description": "Defer a function call"
    },
    "Import": {
        "prefix": "import",
        "body": [
            "import ${1:module};"
        ],
        "description": "Module import"
    },
    "Module skeleton": {
        "prefix": "module",
        "body": [
            "module ${1:name};",
            "",
            "${2:import io;}",
            "",
            "init {",
            "    $0",
            "}"
        ],
        "description": "Module declaration with init block (imperative setup goes inside init in module files)"
    },
    "Init block": {
        "prefix": "init",
        "body": [
            "init {",
            "    $0",
            "}"
        ],
        "description": "init { ... } - one-shot setup at module load time"
    },
    "Export function": {
        "prefix": "export",
        "body": [
            "export func ${1:name}(${2:params}): ${3:void} {",
            "\t$0",
            "}"
        ],
        "description": "Export a function from a module"
    },
    "Generic function": {
        "prefix": "genericfunc",
        "body": [
            "func ${1:name}<${2:T}>(${2:T} ${3:value}): ${2:T} {",
            "\t$0",
            "\treturn ${3:value};",
            "}"
        ],
        "description": "Generic function with one type parameter"
    },
    "Generic function with interface constraint": {
        "prefix": "genericinterface",
        "body": [
            "func ${1:name}<${2:T} implements ${3:Iface}>(${2:T} ${4:value}): ${5:int} {",
            "\treturn ${4:value}.${6:method}();",
            "}"
        ],
        "description": "Generic function where T must satisfy an interface"
    },
    "Generic lambda over outer T": {
        "prefix": "genericlambda",
        "body": [
            "func(${1:T} ${2:x}): ${3:int} { return ${2:x}.${4:method}(); }"
        ],
        "description": "Anonymous function whose T resolves to the outer generic frame"
    },
    "Reified type test": {
        "prefix": "typetest",
        "body": [
            "func ${1:isType}<${2:T}>(any ${3:value}): bool {",
            "\treturn ${3:value} instanceof ${2:T};",
            "}"
        ],
        "description": "Reified runtime type test - call as fn<int>(x) and the body sees T = int"
    },
    "functools idioms": {
        "prefix": "functools",
        "body": [
            "import functools;",
            "",
            "let ${1:run} = functools.pipe([${2:fn1}, ${3:fn2}]);",
            "let ${4:fast} = functools.memoize(${5:expensive});"
        ],
        "description": "Common functools idioms - pipe and memoize"
    },
    "async.rate throttle / debounce": {
        "prefix": "asyncrate",
        "body": [
            "import async.rate as rate;",
            "",
            "let ${1:throttled} = rate.throttle(${2:fn}, ${3:200});",
            "let ${4:debounced} = rate.debounce(${5:fn}, ${6:300});"
        ],
        "description": "Rate-limited callable wrappers"
    },
    "async.all wait for every task": {
        "prefix": "asyncall",
        "body": [
            "let ${1:results} = await async.all([${2:taskA}, ${3:taskB}]);"
        ],
        "description": "Wait for every task; cancel siblings on first failure"
    },
    "async.race first finisher wins": {
        "prefix": "asyncrace",
        "body": [
            "let ${1:winner} = await async.race([${2:primary}, ${3:backup}]);"
        ],
        "description": "Return the first task to finish; cancel the rest"
    },
    "async.timeout deadline a task": {
        "prefix": "asynctimeout",
        "body": [
            "try {",
            "    let ${1:result} = await async.timeout(${2:task}, ${3:1000});",
            "} catch (Error ${4:e}) {",
            "    $0",
            "}"
        ],
        "description": "Cancel a task if it does not complete in time"
    },
    "async.cancel a running task": {
        "prefix": "asynccancel",
        "body": [
            "${1:task}.cancel();"
        ],
        "description": "Cancel a running task (alias for async.cancel(task))"
    },
    "crypt.aesEncrypt AES-256-GCM": {
        "prefix": "aesencrypt",
        "body": [
            "let ${1:enc} = crypt.aesEncrypt(${2:key}, ${3:plaintext});",
            "# ${1:enc}[\"nonce\"], ${1:enc}[\"ciphertext\"] are bytes"
        ],
        "description": "Encrypt with AES-256-GCM (key must be 32 bytes)"
    },
    "crypt.aesDecrypt AES-256-GCM": {
        "prefix": "aesdecrypt",
        "body": [
            "let ${1:plaintext} = crypt.aesDecrypt(${2:key}, ${3:enc}[\"nonce\"], ${3:enc}[\"ciphertext\"]);"
        ],
        "description": "Decrypt an AES-256-GCM ciphertext"
    },
    "crypt.chacha20Encrypt XChaCha20-Poly1305": {
        "prefix": "chacha20encrypt",
        "body": [
            "let ${1:enc} = crypt.chacha20Encrypt(${2:key}, ${3:plaintext});"
        ],
        "description": "Encrypt with XChaCha20-Poly1305 (key must be 32 bytes)"
    },
    "crypt.chacha20Decrypt XChaCha20-Poly1305": {
        "prefix": "chacha20decrypt",
        "body": [
            "let ${1:plaintext} = crypt.chacha20Decrypt(${2:key}, ${3:enc}[\"nonce\"], ${3:enc}[\"ciphertext\"]);"
        ],
        "description": "Decrypt an XChaCha20-Poly1305 ciphertext"
    },
    "re.match with capture groups": {
        "prefix": "rematch",
        "body": [
            "let ${1:m} = re.match(\"${2:pattern}\", ${3:text});",
            "if (${1:m} != null) {",
            "    io.println(${1:m}[\"text\"]);",
            "    io.println(${1:m}[\"groups\"][1]);",
            "    $0",
            "}"
        ],
        "description": "Match a regex and read capture groups via .text / .groups / .named"
    },
    "re.matchAll iterate matches": {
        "prefix": "rematchall",
        "body": [
            "for (${1:m} in re.matchAll(\"${2:pattern}\", ${3:text})) {",
            "    io.println(${1:m}[\"text\"]);",
            "    $0",
            "}"
        ],
        "description": "Iterate every non-overlapping regex match"
    },
    "http.newClient with cookie jar": {
        "prefix": "httpsession",
        "body": [
            "let ${1:jar} = http.newCookieJar();",
            "let ${2:client} = http.newClient({",
            "    \"cookieJar\": ${1:jar},",
            "    \"baseUrl\":   \"${3:https://api.example.com}\",",
            "    \"timeoutMs\": ${4:5000}",
            "});",
            "$0"
        ],
        "description": "Reusable HTTP client with a cookie jar and base URL"
    },
    "time.scheduler Timer": {
        "prefix": "schedtimer",
        "body": [
            "import time.scheduler as sched;",
            "let ${1:t} = sched.Timer(${2:1000}, func(): void {",
            "    $0",
            "});"
        ],
        "description": "Fire a callback once after N ms (cancellable)"
    },
    "time.scheduler Ticker": {
        "prefix": "schedticker",
        "body": [
            "import time.scheduler as sched;",
            "let ${1:ticker} = sched.Ticker(${2:1000}, func(): void {",
            "    $0",
            "});",
            "# ...",
            "${1:ticker}.stop();"
        ],
        "description": "Fire a callback every N ms until stopped"
    },
    "encoding.base32 encode/decode": {
        "prefix": "base32",
        "body": [
            "let ${1:enc} = encoding.base32Encode(${2:value});",
            "let ${3:dec} = encoding.base32Decode(${1:enc});"
        ],
        "description": "Base32 encode / decode (RFC 4648)"
    },
    "encoding.base58 encode/decode": {
        "prefix": "base58",
        "body": [
            "let ${1:enc} = encoding.base58Encode(${2:value});",
            "let ${3:dec} = encoding.base58Decode(${1:enc});"
        ],
        "description": "Base58 encode / decode (Bitcoin/IPFS alphabet)"
    },
    "http.newClient with proxy": {
        "prefix": "httpproxy",
        "body": [
            "let ${1:client} = http.newClient({",
            "    \"proxy\":       \"${2:http://proxy.example.com:3128}\",",
            "    \"keepAlive\":   true,",
            "    \"maxIdleConns\": ${3:32}",
            "});",
            "$0"
        ],
        "description": "HTTP client routed through an explicit proxy"
    },
    "time stopwatch idiom": {
        "prefix": "stopwatch",
        "body": [
            "import time;",
            "",
            "let ${1:start} = time.now();",
            "$0",
            "io.println(\"took \" + (time.elapsed(${1:start}) as string) + \" ms\");"
        ],
        "description": "Measure elapsed time with time.now and time.elapsed"
    },
    "cli.color styled output": {
        "prefix": "color",
        "body": [
            "import cli.color as color;",
            "",
            "io.println(color.bold(color.green(\"${1:ok}\")) + \"  ${2:message}\");"
        ],
        "description": "ANSI-styled CLI output (NO_COLOR aware)"
    },
    "Try/catch block": {
        "prefix": "trycatch",
        "body": [
            "try {",
            "\t$0",
            "} catch (${1:Error} ${2:e}) {",
            "\tio.println(${2:e}.message);",
            "}"
        ],
        "description": "Try/catch block with typed exception parameter"
    },
    "Static const class member": {
        "prefix": "staticconst",
        "body": [
            "static const ${1:NAME} = ${2:value};"
        ],
        "description": "Immutable class-level constant"
    },
    "Static let class member": {
        "prefix": "staticlet",
        "body": [
            "static let ${1:name} = ${2:value};"
        ],
        "description": "Mutable class-level field (untyped)"
    },
    "Static typed class field": {
        "prefix": "statictyped",
        "body": [
            "static ${1:int} ${2:name} = ${3:0};"
        ],
        "description": "Mutable class-level field with declared type"
    },
    "Destructor declaration": {
        "prefix": "destructor",
        "body": [
            "func ~${1:ClassName}() {",
            "\t$0",
            "}"
        ],
        "description": "Class destructor; runs at program exit or on `del x` (end-of-lifetime hook, NOT tied to `with`)"
    },
    "del statement": {
        "prefix": "del",
        "body": [
            "del ${1:name};"
        ],
        "description": "Retire a binding: fires the class destructor (if any) inline and removes the name; subsequent use is a static error"
    },
    "with block (binding)": {
        "prefix": "with",
        "body": [
            "with (${1:name} = ${2:resource}) {",
            "\t$0",
            "}"
        ],
        "description": "Context-manager block: invokes __enter__() on entry and __exit__() on exit (any exit path)"
    },
    "Context manager (__enter__/__exit__)": {
        "prefix": "contextmgr",
        "body": [
            "class ${1:Guarded} {",
            "\tfunc ${1:Guarded}(${2:args}) {",
            "\t\t$0",
            "\t}",
            "\tfunc __enter__(): ${3:any} {",
            "\t\treturn this;",
            "\t}",
            "\tfunc __exit__(): void {",
            "\t}",
            "}"
        ],
        "description": "Class with __enter__ / __exit__ for `with`-block semantics"
    },
    "__serialize__ override": {
        "prefix": "serialize",
        "body": [
            "func __serialize__(): dict {",
            "\treturn {",
            "\t\t\"${1:field}\": this.${1:field}$0",
            "\t};",
            "}"
        ],
        "description": "Custom serialisation hook (used by json/yaml/toml.stringify)"
    },
    "__deserialize__ static factory": {
        "prefix": "deserialize",
        "body": [
            "static func __deserialize__(dict d): ${1:ClassName} {",
            "\treturn ${1:ClassName}(d[\"${2:field}\"]$0);",
            "}"
        ],
        "description": "Custom deserialisation factory (used by json/yaml/toml.parseAs)"
    },
    "__string cast dunder": {
        "prefix": "castString",
        "body": [
            "func __string(): string {",
            "\treturn \"${1:value}\";$0",
            "}"
        ],
        "description": "Cast overload: `instance as string`"
    },
    "__int cast dunder": {
        "prefix": "castInt",
        "body": [
            "func __int(): int {",
            "\treturn ${1:0};$0",
            "}"
        ],
        "description": "Cast overload: `instance as int`"
    },
    "__float cast dunder": {
        "prefix": "castFloat",
        "body": [
            "func __float(): float {",
            "\treturn ${1:0.0};$0",
            "}"
        ],
        "description": "Cast overload: `instance as float`"
    },
    "__bool cast dunder": {
        "prefix": "castBool",
        "body": [
            "func __bool(): bool {",
            "\treturn ${1:true};$0",
            "}"
        ],
        "description": "Cast overload: `instance as bool`"
    },
    "__decimal cast dunder": {
        "prefix": "castDecimal",
        "body": [
            "func __decimal(): decimal {",
            "\treturn ${1:0d};$0",
            "}"
        ],
        "description": "Cast overload: `instance as decimal`"
    },
    "__bytes cast dunder": {
        "prefix": "castBytes",
        "body": [
            "func __bytes(): bytes {",
            "\treturn bytes.fromString(\"${1:value}\");$0",
            "}"
        ],
        "description": "Cast overload: `instance as bytes`"
    },
    "StringBuilder builder-backed accumulator": {
        "prefix": "stringbuilder",
        "body": [
            "let ${1:sb} = strings.StringBuilder();",
            "${1:sb}.append(\"${2:fragment}\");",
            "$0",
            "let ${3:result} = ${1:sb}.build();",
            "${1:sb}.dispose();"
        ],
        "description": "strings.StringBuilder: amortised O(n) accumulator for tight-loop string assembly"
    }
}
