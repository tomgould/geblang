import io;

func greet(string name, string greeting = "Hello"): string {
    return greeting + ", " + name;
}
io.println(greet("Amy"));
io.println(greet("Bob", "Hi"));

func sum(int... nums): int {
    let total = 0;
    for (n in nums) { total = total + n; }
    return total;
}
io.println(sum());
io.println(sum(1, 2, 3));
let xs = [4, 5, 6];
io.println(sum(...xs));

class Calc {
    int base;
    func Calc(int base) { this.base = base; }
    func add(int x, int y = 100): int { return this.base + x + y; }
    func total(int... vals): int {
        let t = this.base;
        for (v in vals) { t = t + v; }
        return t;
    }
}
let c = Calc(1);
io.println(c.add(2));
io.println(c.add(2, 3));
io.println(c.total(10, 20));
let more = [5, 5];
io.println(c.total(...more));
