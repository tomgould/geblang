/**
 * @title List mutators
 * @summary In-place list mutators that reassign an addressable receiver.
 * @category General
 */
import io;

func showInts(list<int> xs) {
    string out = "";
    for (int i = 0; i < xs.length(); i++) {
        out = out + (xs[i] as string);
        if (i < xs.length() - 1) {
            out = out + ",";
        }
    }
    io.println(out);
}

list<int> acc = [];
for (int i = 1; i <= 4; i++) {
    acc.push(i * i);
}
showInts(acc);

acc.pop();
showInts(acc);

acc.prepend(0);
showInts(acc);

acc.insert(2, 99);
showInts(acc);

acc.removeAt(0);
showInts(acc);

acc.remove(99);
showInts(acc);

acc.reverse();
showInts(acc);

acc.sort();
showInts(acc);

class Bag {
    list<int> items = [];

    func add(int v) {
        this.items.push(v);
    }

    func total(): int {
        int sum = 0;
        for (n in this.items) {
            sum = sum + n;
        }
        return sum;
    }
}

Bag bag = Bag();
bag.add(3);
bag.add(7);
bag.add(5);
io.println(bag.total());

let y = acc.push(42);
showInts(acc);
io.println(y.length());
