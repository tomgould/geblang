// === main/main.go ===
package main

import (
	"fmt"
	"geblang/pkg/transpilert"
)

type Result interface{ __gbResult() }

type ResultOk struct {
	V0 string
}

func (ResultOk) __gbResult() {}

func NewResultOk(v0 string) ResultOk {
	return ResultOk{V0: v0}
}

func (__v ResultOk) String() string {
	return "Result.Ok(" + fmt.Sprintf("%v", __v.V0) + ")"
}

type ResultErr struct {
	V0 string
}

func (ResultErr) __gbResult() {}

func NewResultErr(v0 string) ResultErr {
	return ResultErr{V0: v0}
}

func (__v ResultErr) String() string {
	return "Result.Err(" + fmt.Sprintf("%v", __v.V0) + ")"
}

func main() {
	var r1 Result = NewResultOk("hello")
	var r2 Result = NewResultErr("oops")
	fmt.Println(transpilert.Show(r1))
	fmt.Println(transpilert.Show(r2))
	fmt.Println(transpilert.Show((r1 == NewResultOk("hello"))))
	fmt.Println(transpilert.Show((r1 == NewResultErr("hello"))))
	fmt.Println(transpilert.Show(func() bool { _, __ok := any(r1).(Result); return __ok }()))
	fmt.Println(transpilert.Show(func() bool { _, __ok := any(r1).(ResultOk); return __ok }()))
	fmt.Println(transpilert.Show(func() bool { _, __ok := any(r1).(ResultErr); return __ok }()))
}
