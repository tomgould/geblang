// === main/main.go ===
package main

import (
	"fmt"
	"geblang/pkg/transpilert"
	"math/big"
)

func gbDecimalLit(s string) *big.Rat {
	r, ok := new(big.Rat).SetString(s)
	if !ok {
		panic("invalid decimal literal: " + s)
	}
	return r
}

func gbDecimalToFloat(r *big.Rat) float64 {
	f, _ := r.Float64()
	return f
}

func gbFloatToInt(v float64) int64 { return int64(v) }

func main() {
	var port int64 = 8080
	var tls bool = true
	fmt.Println(transpilert.Show(("port=" + fmt.Sprintf("%v", port))))
	fmt.Println(transpilert.Show(("tls=" + fmt.Sprintf("%v", tls))))
	fmt.Println(transpilert.Show(gbFloatToInt(gbDecimalToFloat(gbDecimalLit("3.7")))))
	fmt.Println(transpilert.Show(float64(5)))
	fmt.Println(transpilert.Show(fmt.Sprintf("%v", -5)))
}
