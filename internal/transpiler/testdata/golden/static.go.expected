// === main/main.go ===
package main

import (
	"fmt"
	"geblang/pkg/transpilert"
)

type MathUtils struct {
}

func NewMathUtils() *MathUtils {
	this := &MathUtils{}
	return this
}

func MathUtils_double(n int64) int64 {
	return (n * 2)
}

func MathUtils_square(n int64) int64 {
	return (n * n)
}

func MathUtils_add(a int64, b int64) int64 {
	return (a + b)
}

var __decorators_MathUtils = []*transpilert.OrderedDict[string, any]{}

var __methods_MathUtils = []string{}

var __fields_MathUtils = []string{}

func main() {
	fmt.Println(transpilert.Show(MathUtils_double(5)))
	fmt.Println(transpilert.Show(MathUtils_square(4)))
	fmt.Println(transpilert.Show(MathUtils_add(3, 4)))
}
