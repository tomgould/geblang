import io;

func describe(string name, int age): string {
    return name + " is " + (age as string);
}

class Point {
    int x;
    int y;

    func Point(int x, int y) {
        this.x = x;
        this.y = y;
    }

    func show(): string {
        return "(" + (this.x as string) + ", " + (this.y as string) + ")";
    }
}

io.println(describe(age: 30, name: "Ada"));
io.println(describe("Bob", age: 25));

Point p = Point(y: 4, x: 3);
io.println(p.show());
