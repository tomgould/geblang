import io;

class Point {
    int x;
    int y;
    func Point(int x, int y) { this.x = x; this.y = y; }
}

class Named {
    string n;
    func Named(string n) { this.n = n; }
    func __string(): string { return "Named(" + this.n + ")"; }
}

let p = Point(1, 2);
io.println(p);
io.println([p]);

let nm = Named("bob");
io.println(nm);
io.println([nm]);
