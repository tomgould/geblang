// === main/main.go ===
package main

import (
	"fmt"
	"geblang/pkg/transpilert"
)

func double(n int64) int64 {
	return (n * 2)
}

func sumEvensTo(n int64) int64 {
	var total int64 = 0
	var i int64 = 0
	for i <= n {
		i = (i + 1)
		if (i % 2) != 0 {
			continue
		}
		if i > 100 {
			break
		}
		total = (total + i)
	}
	return total
}

func main() {
	fmt.Println(transpilert.Show(double(5)))
	fmt.Println(transpilert.Show(double(-3)))
	fmt.Println(transpilert.Show(sumEvensTo(10)))
	fmt.Println(transpilert.Show(!true))
}
