// === main/main.go ===
package main

import (
	"fmt"
	"geblang/pkg/transpilert"
	"math/big"
)

func gbDecimalLit(s string) *big.Rat {
	r, ok := new(big.Rat).SetString(s)
	if !ok {
		panic("invalid decimal literal: " + s)
	}
	return r
}

func main() {
	fmt.Println(transpilert.Show([]int64{1, 2, 3}))
	fmt.Println(transpilert.Show([][]int64{[]int64{1, 2}, []int64{3, 4}}))
	fmt.Println(transpilert.Show([]string{"a", "b", "c"}))
	fmt.Println(transpilert.Show([]float64{3.14, 2.0}))
	d := func() *transpilert.OrderedDict[string, int64] {
		__d := transpilert.NewOrderedDict[string, int64]()
		__d.Set("k", 1)
		__d.Set("k2", 2)
		return __d
	}()
	fmt.Println(transpilert.Show(d))
	nested := func() *transpilert.OrderedDict[string, any] {
		__d := transpilert.NewOrderedDict[string, any]()
		__d.Set("name", "alice")
		__d.Set("tags", []string{"x", "y"})
		return __d
	}()
	fmt.Println(transpilert.Show(nested))
	fmt.Println(transpilert.Show(42))
	fmt.Println(transpilert.Show(true))
	fmt.Println(transpilert.Show(false))
	fmt.Println(transpilert.Show("hello"))
	fmt.Println(transpilert.Show("with \"quote\""))
	fmt.Println(transpilert.Show(1.0))
	fmt.Println(transpilert.Show(100.0))
	fmt.Println(transpilert.Show(0.5))
	fmt.Println(transpilert.Show(3.14))
	fmt.Println(transpilert.Show(gbDecimalLit("2.5")))
	fmt.Println(transpilert.Show([]*big.Rat{gbDecimalLit("1.5"), gbDecimalLit("2.0")}))
	label := "world"
	fmt.Println(transpilert.Show(fmt.Sprintf("hello %v", transpilert.Show(label))))
	xs := []int64{1, 2, 3}
	fmt.Println(transpilert.Show(fmt.Sprintf("list is %v", transpilert.Show(xs))))
}
