// === main/main.go ===
package main

import (
	"fmt"
	"geblang/pkg/transpilert"
)

func helper_greet(name string) string {
	return (("Hello, " + name) + "!")
}

func helper_square(n int64) int64 {
	return (n * n)
}

func helper_sum(a int64, b int64, c int64, d int64, e int64) int64 {
	return ((((a + b) + c) + d) + e)
}

func main() {
	fmt.Println(transpilert.Show(helper_greet("World")))
	fmt.Println(transpilert.Show(helper_square(7)))
	fmt.Println(transpilert.Show(helper_sum(1, 2, 3, 4, 5)))
}
