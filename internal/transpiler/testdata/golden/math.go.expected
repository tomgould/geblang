// === main/main.go ===
package main

import (
	"fmt"
	"geblang/pkg/transpilert"
	"math"
	"math/big"
)

func gbDecimalLit(s string) *big.Rat {
	r, ok := new(big.Rat).SetString(s)
	if !ok {
		panic("invalid decimal literal: " + s)
	}
	return r
}

func gbDecimalToFloat(r *big.Rat) float64 {
	f, _ := r.Float64()
	return f
}

func main() {
	fmt.Println(transpilert.Show(math.Abs(float64(-5))))
	fmt.Println(transpilert.Show(min(3, 1, 2)))
	fmt.Println(transpilert.Show(max(3, 1, 2)))
	fmt.Println(transpilert.Show(min(max(12, 0), 10)))
	fmt.Println(transpilert.Show(int64(math.Floor(gbDecimalToFloat(gbDecimalLit("3.7"))))))
	fmt.Println(transpilert.Show(int64(math.Ceil(gbDecimalToFloat(gbDecimalLit("3.1"))))))
	fmt.Println(transpilert.Show(int64(math.Round(gbDecimalToFloat(gbDecimalLit("3.5"))))))
	fmt.Println(transpilert.Show(math.Sqrt(float64(9))))
	fmt.Println(transpilert.Show(math.Pow(float64(2), float64(3))))
	fmt.Println(transpilert.Show(math.Sin(float64(0))))
	fmt.Println(transpilert.Show(math.Pi))
	fmt.Println(transpilert.Show(math.E))
}
