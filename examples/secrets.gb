/**
 * @title Secrets
 * @summary Demonstrates secrets in a runnable Geblang example.
 * @category General
 */
import io;
import secrets;
import sys;

sys.setenv("GEBLANG_EXAMPLE_SECRET", "env-secret");

io.println(secrets.requireEnv("GEBLANG_EXAMPLE_SECRET"));
let n = secrets.randomInt(1, 10);
io.println(n >= 1 && n <= 10);
io.println(secrets.randomHex(8).length());
io.println(secrets.randomBytes(4).length());
io.println(secrets.constantTimeEqual("same", "same"));
io.println(secrets.constantTimeEqual("same", "different"));
