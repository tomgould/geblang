/**
 * @title Http Server
 * @summary Demonstrates http server in a runnable Geblang example.
 * @category General
 */
import http;

/* Declare the parameter as `Request` to opt into the rich request object and
 * return a `Response` from the http builders. http.response sends text/plain
 * 200 by default. (A dict-in/dict-out handler still works for back-compat.) */
func app(Request req): Response {
    return http.response("Geblang ${req.method} ${req.path}");
}

http.serve("127.0.0.1:8080", app);
