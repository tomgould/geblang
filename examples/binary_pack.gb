import binary;
import bytes;
import io;

/**
 * Build a fake network packet header: 4-byte magic, 2-byte length,
 * 1-byte version, then a 10-byte name field.
 */
let packet = binary.pack(">IHB10s",
    0xDEADBEEF,
    42,
    1,
    "alice");

io.println("hex:  " + bytes.toHex(packet));
io.println("size: " + binary.size(">IHB10s").toString());

/* Decode flat: get back a list of values in declaration order. */
let parts = binary.unpack(">IHB10s", packet);
io.println("magic   = " + parts[0].toString(16));
io.println("length  = " + parts[1].toString());
io.println("version = " + parts[2].toString());
io.println("nameRaw = " + bytes.toHex(parts[3] as bytes));

/* Decode named: get back a dict for easy field access. */
let header = binary.unpackNamed([
    {"name": "magic",   "type": ">I"},
    {"name": "length",  "type": "H"},
    {"name": "version", "type": "B"},
    {"name": "name",    "type": "10s"}
], packet);
io.println("named magic   = " + (header["magic"] as int).toString(16));
io.println("named version = " + (header["version"] as int).toString());
