/**
 * @title Collections Lazy
 * @summary Demonstrates collections lazy in a runnable Geblang example.
 * @category General
 */
import collections;
import io;

let doubled = collections.lazyMap(collections.range(1, 10), func(int x): int {
    return x * 2;
});

let divisibleByFour = collections.lazyFilter(doubled, func(int x): bool {
    return x % 4 == 0;
});

for (n in collections.take(divisibleByFour, 3)) {
    io.println(n);
}

for (n in collections.range(5, 0, -2)) {
    io.println(n);
}
