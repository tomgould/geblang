/**
 * @title Enums
 * @summary Demonstrates enums in a runnable Geblang example.
 * @category General
 */
import io;

# Simple enum - no associated data

enum Direction { North, South, East, West }

Direction heading = Direction.North;
io.println(heading);                        # Direction.North
io.println(heading == Direction.North);     # true
io.println(heading == Direction.South);     # false
io.println(heading instanceof Direction);   # true

# Tagged enum - variants carry associated values

enum Result { Ok(string), Err(string) }

Result ok = Result.Ok("hello");
Result err = Result.Err("something went wrong");

io.println(ok);   # Result.Ok(hello)
io.println(err);  # Result.Err(something went wrong)

io.println(ok == Result.Ok("hello"));  # true
io.println(ok == Result.Err("hello")); # false

# instanceof with a specific variant

io.println(ok instanceof Result);        # true
io.println(ok instanceof Result.Ok);     # true
io.println(ok instanceof Result.Err);    # false

# match on simple enum variants - handle every variant so `geblang check`
# confirms exhaustiveness (no default needed)

func describe(Direction d): string {
    return match (d) {
        case Direction.North => "heading north";
        case Direction.South => "heading south";
        case Direction.East  => "heading east";
        case Direction.West  => "heading west";
    };
}

io.println(describe(Direction.North));  # heading north
io.println(describe(Direction.East));   # heading east
io.println(describe(Direction.West));   # heading west

# static surface on the enum type itself

io.println(Direction.values());                       # [Direction.North, Direction.South, Direction.East, Direction.West]
io.println(Direction.fromName("South") == Direction.South);  # true
io.println(Direction.fromName("Nope") == null);              # true

# match on tagged enum variants with payload destructuring

func handle(Result r): string {
    return match (r) {
        case Result.Ok(string msg)  => "success: " + msg;
        case Result.Err(string msg) => "failure: " + msg;
    };
}

io.println(handle(Result.Ok("data loaded")));       # success: data loaded
io.println(handle(Result.Err("connection refused"))); # failure: connection refused

# Enum with multiple payload fields

enum Shape { Circle(decimal), Rect(decimal, decimal) }

Shape c = Shape.Circle(5.0);
Shape r = Shape.Rect(3.0, 4.0);

io.println(c);  # Shape.Circle(5.0000000000)
io.println(r);  # Shape.Rect(3.0000000000, 4.0000000000)

func area(Shape s): decimal {
    return match (s) {
        case Shape.Circle(decimal radius) => 3.14159 * radius * radius;
        case Shape.Rect(decimal w, decimal h) => w * h;
    };
}

io.println(area(Shape.Circle(5.0)));    # 78.5397500000
io.println(area(Shape.Rect(3.0, 4.0))); # 12.0000000000
