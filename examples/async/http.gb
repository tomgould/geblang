/**
 * @title Http
 * @summary Demonstrates http in a runnable Geblang example.
 * @category Async
 */
import async.http as ahttp;
import http;
import io;

func handle(Request req): Response {
    return http.response("async http " + req.path);
}

let server = http.listen("127.0.0.1:0", handle);
let addr = http.serverAddr(server);
let task = ahttp.get("http://" + addr + "/hello");
let response = await task;

io.println(response.text());

http.shutdown(server, 1000);
http.close(server);
