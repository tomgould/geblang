/**
 * @title Ext Python
 * @summary Demonstrates ext python in a runnable Geblang example.
 * @category General
 */
import ext;
import io;
import bytes;

let conn = ext.load("python_example");

io.println(ext.functions(conn).contains("greet") as string);
io.println(ext.call(conn, "add", 19, 23) as string);
io.println(ext.call(conn, "greet", name: "Geblang"));
io.println(ext.call(conn, "echo", bytes.fromHex("0102ff")).toHex());

ext.close(conn);
