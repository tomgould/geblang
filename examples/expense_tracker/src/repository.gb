/**
 * @title Repository
 * @summary Demonstrates repository in a runnable Geblang example.
 * @category Expense Tracker
 */
module expense.tracker.repository;

export class ExpenseRepository {
    list<any> items;

    func ExpenseRepository() {
        this.items = [];
    }

    func add(any expense): void {
        this.items = this.items.push(expense);
    }

    func all(): list<any> {
        return this.items;
    }

    func totalCents(): int {
        int total = 0;
        for (expense in this.items) {
            total = total + expense.cents;
        }
        return total;
    }
}

export func newRepository(): ExpenseRepository {
    return ExpenseRepository();
}
