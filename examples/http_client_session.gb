/**
 * @title Http Client Session
 * @summary Cookie jar, keep-alive, and proxy options on http.newClient.
 * @category General
 */
import http;
import io;

# A tiny local server that sets a session cookie on /login and echoes it
# back on /me. We use it to demonstrate the cookieJar option without
# depending on any external service.
func handle(Request req): Response {
    if (req.path == "/login") {
        return http.response("logged in")
            .withHeader("Set-Cookie", "sid=abc123; Path=/");
    }
    let c = req.header("Cookie");
    if (c == null) {
        return http.response("no session", 401);
    }
    return http.response(c as string);
}

let server = http.listen("127.0.0.1:0", handle);
let base = "http://" + http.serverAddr(server);

# 1. Default client - no shared state, no cookies.
let plain = http.newClient();
plain.get(base + "/login");
io.println("plain   /me -> " + plain.get(base + "/me").text());
# -> "no session"

# 2. cookieJar=true attaches a fresh jar for this client only.
let auto = http.newClient({"cookieJar": true});
auto.get(base + "/login");
io.println("auto    /me -> " + auto.get(base + "/me").text());

# 3. Explicit jar lets you inspect and persist cookies across runs.
let jar = http.newCookieJar();
let session = http.newClient({
    "cookieJar":  jar,
    "baseUrl":    base,
    "timeoutMs":  5000,
    "keepAlive":  true,
    "maxIdleConns": 16
});
session.get("/login");
io.println("session /me -> " + session.get("/me").text());

for (cookie in jar.cookies(base)) {
    io.println("  cookie " + cookie["name"] + "=" + cookie["value"]
               + " (path=" + cookie["path"] + ")");
}

# 4. Proxy options - proxyFromEnv honours HTTP_PROXY/HTTPS_PROXY/NO_PROXY.
#    Use "proxy": "http://host:port" to hard-code a proxy URL instead.
let viaProxy = http.newClient({"proxyFromEnv": true});
io.println("proxyFromEnv /login -> "
           + (viaProxy.get(base + "/login").status() as string));

http.shutdown(server, 1000);
http.close(server);
