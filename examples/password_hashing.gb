import crypt;
import io;

/**
 * Default: bcrypt at cost 10, $2y$ prefix (matches PHP password_hash).
 */
let hash = crypt.passwordHash("hunter2");
io.println("default:    " + hash.substring(0, 7) + "...");
io.println("verify ok:  " + crypt.passwordVerify("hunter2", hash).toString());
io.println("verify bad: " + crypt.passwordVerify("wrong", hash).toString());

/**
 * Argon2id with custom parameters.
 */
let argonHash = crypt.passwordHash("hunter2", {
    "algorithm":   "argon2id",
    "memory":      131072,
    "time":        4,
    "parallelism": 2
});
io.println("argon2id:   " + argonHash.substring(0, 30) + "...");
io.println("verify ok:  " + crypt.passwordVerify("hunter2", argonHash).toString());

/**
 * A hash produced by PHP's password_hash() verifies the same way.
 */
let phpHash = "$2y$10$zPqulg/ZGaIWXJd.lgeakufxSj.JdvVxZtGhQun6Wiyx44OXEqDzi";
io.println("php hash ok: " + crypt.passwordVerify("hunter2", phpHash).toString());
