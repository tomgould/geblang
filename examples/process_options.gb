/**
 * @title Process Options
 * @summary Demonstrates process options in a runnable Geblang example.
 * @category General
 */
import io;
import sys;

let result = sys.runWithOptions({
    "command": "sh",
    "args": ["-c", "printf $GEB_EXAMPLE"],
    "env": {"GEB_EXAMPLE": "hello"},
    "timeoutMs": 1000
});

io.println(result["code"]);
io.println(result["stdout"]);
io.println(result["timedOut"]);

let proc = sys.startWithOptions({
    "command": "sh",
    "args": ["-c", "printf started"]
});

io.println(sys.processReadStdout(proc));
io.println(sys.processWait(proc));
