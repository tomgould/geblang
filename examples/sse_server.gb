/**
 * @title Sse Server
 * @summary Demonstrates sse server in a runnable Geblang example.
 * @category General
 */
import http;
import io;
import sys;
import web.sse as sse;

func events(Request req): dict<string, any> {
    return sse.streaming(func(sse.EventStream stream): void {
        stream.write(sse.comment("connected"));
        stream.flush();
        for (n in 1..3) {
            stream.write(sse.event("tick", "count " + (n as string), {"id": n as string}));
            stream.flush();
            sys.sleep(250);
        }
        stream.close();
    });
}

func app(Request req): any {
    if (req.path == "/events") {
        return events(req);
    }
    return http.response("<!doctype html><body><pre id=\"log\"></pre><script>const log=document.getElementById('log');const es=new EventSource('/events');es.onmessage=e=>log.textContent+=e.data+'\\n';es.addEventListener('tick',e=>log.textContent+=e.lastEventId+': '+e.data+'\\n');</script></body>")
        .withHeader("Content-Type", "text/html; charset=utf-8");
}

io.println("SSE server listening on http://127.0.0.1:8080");
http.serve("127.0.0.1:8080", app);
