/**
 * @title Ext Tcp Examples
 * @summary Demonstrates ext tcp examples in a runnable Geblang example.
 * @category General
 */
import bytes;
import ext;
import io;

func exercise(string label, string address) {
    let conn = ext.connect(address);
    let functions = ext.functions(conn);

    io.println("${label}:functions:add=${functions.contains("add")}");
    io.println("${label}:functions:greet=${functions.contains("greet")}");
    io.println("${label}:functions:echo=${functions.contains("echo")}");
    io.println("${label}:add=${ext.call(conn, "add", 19, 23)}");
    io.println("${label}:greet=${ext.call(conn, "greet", name: label)}");
    io.println("${label}:greetOptions=${ext.callWithOptions(conn, "greet", {"timeoutMs": 2000, "maxResponseBytes": 1048576}, name: label)}");
    io.println("${label}:echo=${ext.call(conn, "echo", bytes.fromHex("0102ff")).toHex()}");

    ext.close(conn);
}

exercise("python", "127.0.0.1:9101");
exercise("php", "127.0.0.1:9102");
exercise("go", "127.0.0.1:9103");
exercise("node", "127.0.0.1:9104");
