import io;
import sys;
import re;

let args = sys.args();
int n = args.length() > 0 ? args[0].toInt() : 100000;

let pattern = "[a-z]+[0-9]+";
let samples = ["foo123", "bar9", "noatch", "ABC", "xy42z", "z0"];

int hits = 0;
for (int i = 0; i < n; i++) {
    let s = samples[i % samples.length];
    if (re.test(pattern, s)) {
        hits = hits + 1;
    }
}

io.println(hits);
