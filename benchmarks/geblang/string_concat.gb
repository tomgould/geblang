import io;
import sys;

let args = sys.args();
int n = args.length() > 0 ? args[0].toInt() : 20000;
string acc = "";

for (int i = 0; i < n; i++) {
    if (i % 7 == 0) {
        acc = acc + "x";
    } else if (i % 3 == 0) {
        acc = acc + "ab";
    } else {
        acc = acc + "1";
    }
}

io.println(acc.length());
